<script type="text/javascript">
    "use strict";
    /* =========================================================
       GLOBAL STATE
    ========================================================= */
    const state = {
        totalPages: 0,
        currentPage: 0,
        pageSize: 20,
        totalRecords: 0,
        isFirstLoad: true,
        isYearLoad: true,
        isSelectedSearch: 0,
        isChangeDate: 0,
        currentMonth: new Date().getMonth() + 1,
        currentYear: new Date().getFullYear(),
        editRecordId: null,
        isEditMode: false,
        partNo: "",
        dieSerial: "",
        tempDate: "",
        getData: [],
        dailyData: [],
        dieObj: []
    };
    /* =========================================================
       DOM CACHE
    ========================================================= */
    const DOM = {
        tableDisplay: $("#dieMoldMasterlist"),
        dailyDisplay: $("#DieMoldDaily"),
        yearSelect: $("#yearselectDaily"),
        monthSelect: $("#monthSelectDaily"),
        dateInput: $("#DailyfilterDate"),
        processSelect: $("#processSelect"),
        searchInput: $("#searchInput"),
        searchDie: $("#searchDie"),
        validProcess: $("#validprocess"),
        validPart: $("#validDateinput"),
        validDie: $("#validDateDieSerial"),
        dailySummary: $("#DailySummary"),
        detailSummary: $("#DieSerialMasterlist"),
        dailyInputs: $("#DailyInputs"),
        filterProcess: $("#DailyProcess")
    };
    /* =========================================================
       HELPERS
    ========================================================= */
    const showLoader = (btn, text = "Searching...") => {
        btn.dataset.original = btn.innerHTML;
        btn.innerHTML = `<div class="loading"></div> ${text}`;
        btn.disabled = true;
    };
    const hideLoader = btn => {
        btn.innerHTML = btn.dataset.original;
        btn.disabled = false;
    };

    const validateRequired = (...fields) => fields.every(v => v && v.trim() !== "");

    const showAlert = (msg, icon = "error") => Swal.fire({
        icon, text: msg, timer: 1500, showConfirmButton: false,
        allowOutsideClick: false,   // prevent outside click
        allowEscapeKey: false,      // optional: prevent ESC key close
        allowEnterKey: false        // optional: prevent Enter key close
    });
    const buildStatusButton = (label, activeColor = null, onclick = "") => {
        const activeStyle = activeColor
            ? `style="color:${activeColor};border:2px solid ${activeColor};"`
            : "";
        const activeClass = activeColor ? "active" : "";
        return `<button class="status-btn ${activeClass}" ${activeStyle} onclick="${onclick}">${label}</button>`;
    };

    /* =========================================================
       INITIALIZATION
    ========================================================= */
    $(document).ready(() => {
        DOM.dailyInputs.hide();
        DOM.validDie.hide(); DOM.validProcess.hide(); DOM.validPart.hide();

        initMonthSelect("monthSelectDaily", true);
        bindEvents();
        loadDaily();
    });

    /* =========================================================
       EVENT BINDINGS
    ========================================================= */
    function bindEvents() {
        //const addfunc = state.isSelectedSearch === 0 ? handleAddDaily : handleDailyDieSerial;

        $("#addDailyForm").on("submit", handleAddDaily);
        $("#EditPartnumforms").on("submit", handleEditDaily);

        $("#EditDailyforms").on("submit", handleEditDailyDieSerial);

        $("#searchButton").on("click", () => {
            DOM.searchDie.val("");
            runSearch(0);
        });
        $("#searchDieButton").on("click", () => {
            DOM.searchInput.val("");
            runSearch(1);
        });

        DOM.searchInput.on("keypress", e => {
            if (e.key === "Enter") {
                e.preventDefault(); // prevent form submit refresh
                DOM.searchDie.val("");
                runSearch(0);
            }
        });
        DOM.searchDie.on("keypress", e => {
            if (e.key === "Enter") {
                e.preventDefault();
                DOM.searchInput.val("");
                runSearch(1);
            }
        });


        $("#Originalback").on("click", e => {
            e.preventDefault();
            DOM.dailySummary.show();
            DOM.dailyInputs.hide();
            loadDaily();
        });

        DOM.monthSelect.on("change", reloadDailyData);
        DOM.yearSelect.on("change", reloadDailyData);
        DOM.dateInput.on("change", reloadDailyData);
        DOM.filterProcess.on("change", reloadDailyData);

        DOM.tableDisplay.on("click", ".EditDailypartnum", OpenEditDailyModal);
        DOM.tableDisplay.on("click", ".deleteDailypartnumButn", handleDeleteDaily);

        DOM.tableDisplay.on("click", ".EditDailyDieSerial", OpenEditSerialModal);
        DOM.tableDisplay.on("click", ".DeleteDailyDieSerial", handleDeleteDailyDieSerial);

        $("#DailyPartnumDateInput").on("change", () => state.isChangeDate = 1);
        $("#DieSerialDateInput").on("change", () => state.isChangeDate = 1);
    }


    /* =========================================================
                DAILY PARTNUMBER PROCESS
    ========================================================= */
     async function handleAddDaily(e) {
         e.preventDefault();
         let searchval = state.isSelectedSearch === 0 ? $("#searchInput").val().trim() : $("#searchDie").val().trim();

         if (searchval === "" && DOM.processSelect.val()) {
             alert("Check all the required Input");
             return;
         }

         let formData = new FormData(e.target);
         formData.append('ProcessID', DOM.processSelect.val());
         formData.append("PartNo", state.partNo);
         formData.append("DieSerial", state.dieSerial);
         formData.append("SearchMode", state.isSelectedSearch); // 0 = PartNo, 1 = DieSerial

         const data = Object.fromEntries(formData);

          let checkduplicate = await GetMethod('@Url.Action("CheckDialyMoldExist", "Mold")',
              { srcval: searchval, DateInput: data.DateInput });

          // convert to number
          const cycleShot = Number(data.CycleShot);

          // Check for Existing Date record
         if (checkduplicate && cycleShot !== 0) {
             showAlert(data.DateInput + " is Already Input");
              return;
         }

         if (cycleShot === 0 && state.getData.length > 0) {
             const lastrecord = state.getData[0]
             if (Number(lastrecord.Total) === 0) {
                 alert("Zero Cycle Shot is already input on the latest record");
                 return;
             }
         }
         // Insert a new Daily Records
         let res = await postMethod('@Url.Action("SaveDailyMoldDieMonitor", "Mold")', data);
         if (res?.Success) {
             // once the Daily update Automatic Refresh the data
             if (state.isSelectedSearch === 0) {
                 searchByPart();
             } else {
                 searchByDie();
             }
             document.getElementById("addDailyForm").reset();
         } else {
             showAlert("Error  Problem ecounter.");
         }

     }
     async function OpenEditDailyModal() {
        const id = this.id.split("_")[1];
        const row = state.getData.find(r => r.RecordID === parseInt(id));
        if (!row) return;

        $("#DailyPartnumRecordID").val(id);
        $("#DailyEditPartNo").val(row.PartNo);
        setDateInput("DailyPartnumDateInput", row.DateInput);
        $("#DailyPartnumCycleShot").val(row.CycleShot);
        $("#DailyPartnumMachineNo").val(row.MachineNo);
        $("#DailyPartnumRemarks").val(row.Remarks);
        $("#DailyPartnumMincharge").val(row.Mincharge);
        $("#EditPartnumMold").modal("show");
    }
     async function handleEditDaily(e) {
        e.preventDefault();
         let formData = new FormData(e.target);
         const data = Object.fromEntries(formData);

         const findData = state.getData.filter(res =>
             normalizeMMDDYY(res.DateInput) === data.DateInput
         );

         if (findData.length > 0 && state.isChangeDate === 1) {
             showAlert(data.DateInput + " is Already Input");
             return;
         }

         function toDate(value) {
             if (value.includes("/")) {
                 let [m, d, y] = value.split("/");
                 y = y.length === 2 ? `20${y}` : y;
                 return new Date(`${y}-${m.padStart(2, '0')}-${d.padStart(2, '0')}`);
             }
             // Supports YYYY-MM-DD
             return new Date(value);
         }

         const inputDate = toDate(data.DateInput);
         const previousDate = toDate(state.tempDate);

         // 🔴 validation: input date must NOT be after tempDate
         if (inputDate < previousDate) {
             showAlert("Date must not be later than the previous date")
             return;
         }
         let res = await postMethod('@Url.Action("UpdateDailyMoldDieMonitor", "Mold")', formData);

         if (res?.Success) {
             Swal.fire({
                 title: "Success",
                 text: res.Message,
                 icon: "success",
                 confirmButtonColor: "#0d97c9",
                 timer: 1500
             }).then(() => {
                 searchByPart();
                 //SearchByDieNo(strDieSerial);
                 //$("#EditDailyforms")[0].reset();
                 $("#EditPartnumMold").modal("hide");
             });
         }
     }
     async function handleDeleteDaily(e) {
         const id = this.id.split("_")[1];
         const row = state.getData.find(r => r.RecordID === parseInt(id));
         if (!row) return;

            Swal.fire({
                title: "Are you sure you want to delete this?",
                text: "You won't be able to revert this!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                confirmButtonText: "Yes, delete it!"
            }).then(async (result) => {
                if (result.isConfirmed) {
                    let res = await postMethod('@Url.Action("DeletePartnumDailyMoldDieMonitor", "Mold")', {
                        ID: id,
                        partno: row.PartNo,
                        Dateinput: row.DateInput
                    });
                    if (res?.Success) {
                        Swal.fire({
                            title: "Success",
                            text: res.Message,
                            icon: "success",
                            confirmButtonColor: "#0d97c9",
                            timer: 1500
                        }).then(() => {
                            searchByPart();
                        });

                    }
                }
            });

     }

    /* =========================================================
                DAILY DIE SERIAL PROCESS
     ========================================================= */
    async function OpenEditSerialModal() {
        const serial = this.id.split("_")[1];
        const row = state.getData.find(r => r.DateInput === serial);
        if (!row) return;

        $("#DieSerialID").val(row.DieSerial);
        //$("#DailyEditPartNo").val(row.PartNo);
        setDateInput("DieSerialDateInput", row.DateInput);
        $("#DieSerialCycleShot").val(row.CycleShot);
        $("#DieSerialMachineNo").val(row.MachineNo);
        $("#DieSerialRemarks").val(row.Remarks);
        $("#DieSerialMincharge").val(row.Mincharge);
        $("#EditDailyMold").modal("show");
    }
    async function handleEditDailyDieSerial(e) {
        e.preventDefault();
         let formData = new FormData(e.target);
         const data = Object.fromEntries(formData);

         const findData = state.getData.filter(res =>
             normalizeMMDDYY(res.DateInput) === data.DateInput
         );

         if (findData.length > 0 && state.isChangeDate === 1) {
             showAlert(data.DateInput + " is Already Input");
             return;
         }

         function toDate(value) {
             if (value.includes("/")) {
                 let [m, d, y] = value.split("/");
                 y = y.length === 2 ? `20${y}` : y;
                 return new Date(`${y}-${m.padStart(2, '0')}-${d.padStart(2, '0')}`);
             }
             // Supports YYYY-MM-DD
             return new Date(value);
         }

         const inputDate = toDate(data.DateInput);
         const previousDate = toDate(state.tempDate);

         // 🔴 validation: input date must NOT be after tempDate
         if (inputDate < previousDate) {
             showAlert("Date must not be later than the previous date")
             return;
         }

         let res = await postMethod('@Url.Action("UpdateDieSerialMoldDieMonitor", "Mold")', formData);

         if (res?.Success) {
             Swal.fire({
                 title: "Success",
                 text: res.Message,
                 icon: "success",
                 confirmButtonColor: "#0d97c9",
                 timer: 1500
             }).then(() => {
                 searchByDie();
                 $("#EditDailyMold").modal("hide");
             });
         }
     }
    async function handleDeleteDailyDieSerial(e) {
        const serial = this.id.split("_")[1];
        const row = state.getData.find(r => r.DateInput === serial);
        if (!row) return;

         Swal.fire({
             title: "Are you sure you want to delete this?",
             text: "You won't be able to revert this!",
             icon: "warning",
             showCancelButton: true,
             confirmButtonColor: "#3085d6",
             cancelButtonColor: "#d33",
             confirmButtonText: "Yes, delete it!"
         }).then(async (result) => {
             if (result.isConfirmed) {
                 let res = await postMethod('@Url.Action("DeleteDieSerialMoldDieMonitor", "Mold")', {
                     dieSerial: row.DieSerial,
                     Dateinput: serial
                 });
                 if (res?.Success) {
                     Swal.fire({
                         title: "Success",
                         text: res.Message,
                         icon: "success",
                         timer: 2000,
                         showConfirmButton: false,
                         allowOutsideClick: false,   // prevent outside click
                         allowEscapeKey: false,      // optional: prevent ESC key close
                         allowEnterKey: false        // optional: prevent Enter key close
                     }).then(() => {
                         searchByDie();
                     });

                 }
             }
         });

  }

    /* =========================================================
       SEARCH
    ========================================================= */
    async function runSearch(mode) {
        state.isSelectedSearch = mode;
        mode === 0 ? await searchByPart() : await searchByDie();
    }

    async function searchByPart() {

        //DOM.searchDie.val("");
        const part = DOM.searchInput.val().trim();
        const process = DOM.processSelect.val();

        if(!validateRequired(part, process)){
            DOM.validPart.toggle(!part);
            DOM.validProcess.toggle(!process);
            return;
        }

        state.partNo = part;
        DOM.validPart.hide(); DOM.validProcess.hide();

        const btn = document.getElementById("searchButton");
        showLoader(btn);

        try {
            const checkMold = await GetMethod('@Url.Action("SearchRealMoldie", "Mold")', {
                ProcessID: process, SearchInput: part
            });

            if (checkMold.success == false) {
                showAlert(checkMold.message);
                return;
            }

            const res = await GetMethod('@Url.Action("SearchMoldieDaily","Mold")',{
                ProcessID:process, SearchInput:part
            });
            if(!res?.Success) return showNoData();

            DOM.dailyInputs.show();
            DOM.dailySummary.hide();

            state.getData = res.Data.GetList;
            renderPartDetails(res.Data.Details);
            populateTable(state.getData);

        }catch(err){ console.error("asdasd" + err); }
        finally{ hideLoader(btn); }
    }

    async function searchByDie() {
        //DOM.searchInput.val("");

        const die = DOM.searchDie.val().trim();
        const process = DOM.processSelect.val();

        if(!validateRequired(die, process)){
            DOM.validDie.toggle(!die);
            DOM.validProcess.toggle(!process);
            return;
        }

        state.dieSerial = die;
        DOM.validDie.hide(); DOM.validProcess.hide();

        const btn = document.getElementById("searchDieButton");
        showLoader(btn);

        try {
            const checkMold = await GetMethod('@Url.Action("SearchRealMoldie", "Mold")', {
                ProcessID: process, SearchInput: die
            });

            if (checkMold.success == false) {
                showAlert(checkMold.message);
                return;
            }


            const res = await GetMethod('@Url.Action("SearchByDieSerialMoldie","Mold")',{
                ProcessID:process, DieInput:die
            });

            if(!res?.Success) return showNoData();
            DOM.dailyInputs.show();
            DOM.dailySummary.hide();
            //state.partNo = res.Data.Details[0].PartNo;
            //state.dieObj = res.Data.GetList;

            state.getData = res.Data.GetList;
            populateDieSerialDetails(res.Data.Details);
            populateDieTable(state.getData);

        }catch(err){ console.error(err); }
        finally{ hideLoader(btn); }
    }
    /* =========================================================
       TABLE BUILDERS
    ========================================================= */


    function populateTable(list) {
        let counter = 0;
        DOM.tableDisplay.empty();
        list.forEach(row => {
            let actionButton = "";

            if (row.Total === 0) {
                counter = 1;
            }

            if (counter === 0) {
                actionButton = ` <div style='display: grid; grid-template-columns: 50% 50%; gap: 5px;'>
                                   <button type="button" class="text-primary actionicon EditDailypartnum"
                                       id="editButton_${row.RecordID}">
                                       <i class="fa-regular fa-pen-to-square action_btn"></i>
                                   </button>

                                       <button type="button" class="text-danger actionicon  deleteDailypartnumButn"
                                           id="deleteDailyButton_${row.RecordID}">
                                           <i class="fa-regular fa-trash-can"></i>
                                       </button>
                                 </div>`;
                state.tempDate = row.DateInput;
            }

            const statusBtns = buildStatusButtonSet(row.RecordID, row.Status);
            DOM.tableDisplay.append(`<tr>
                <td>${row.DateInput}</td>
                <td>${row.CycleShot}</td>
                <td>${row.Total}</td>
                <td>${row.MachineNo}</td>
                <td>${row.Remarks}</td>
                <td>${row.Mincharge}</td>
                <td><div class="flex_align">${statusBtns}</div></td>
                <td>${actionButton}</td>
            </tr>`);
        });
    }

    function populateDieSerialDetails(details) {
        DOM.detailSummary.empty();

        const $table = $("#DieSerialMasterlist");
        $table.empty();

        if (!details || details.length === 0) return;
        const rowspan = details.length;
        const dieSerial = details[0].DieSerial;
        const status = details[0].Status;


        details.forEach((part, index) => {
            let rowHtml = `<tr>
            <td>${part.PartNo}</td>
            <td>${part.Dimension_Quality}</td>`;

            // Only add merged cells on first row
            if (index === 0) {
                rowHtml += `
                <td rowspan="${rowspan}" class="die-serial">${dieSerial}</td>
                <td rowspan="${rowspan}" class="die-status">${buildStatusBadge(status)}</td>`;
            }

            rowHtml += `</tr>`;
            $table.append(rowHtml);
        });
    }
    function populateDieTable(list) {
        let counter = 0;

        DOM.tableDisplay.empty();
        list.forEach(row => {
            let actionButton = "";

            if (row.Total === 0) {
                counter = 1;
            }

            if (counter === 0) {
                actionButton = ` <div style='display: grid; grid-template-columns: 50% 50%; gap: 5px;'>
                       <button type="button" class="text-primary actionicon EditDailyDieSerial"
                           id="editButton_${row.DateInput}">
                           <i class="fa-regular fa-pen-to-square action_btn"></i>
                       </button>

                           <button type="button" class="text-danger actionicon  DeleteDailyDieSerial"
                               id="deleteDailyButton_${row.DateInput}">
                               <i class="fa-regular fa-trash-can"></i>
                           </button>
                     </div>`;
                state.tempDate = row.DateInput;
            }


            const statusBtns = buildStatusButtonSet(row.RecordID, row.Status, true, row);
            DOM.tableDisplay.append(`<tr>
            <td>${row.DateInput}</td>
            <td>${row.CycleShot}</td>
            <td>${row.Total}</td>
            <td>${row.MachineNo}</td>
            <td>${row.Remarks}</td>
            <td>${row.Mincharge}</td>
            <td><div class="flex_align">${statusBtns}</div></td>
            <td>${actionButton}</td>
        </tr>`);
        });
    }


    function buildStatusButtonSet(id, status, isDie = false, row = null) {
        let actionStatus = "";

        // For the Partnumber
        if (!isDie) {
            actionStatus = `
             <button class='status-btn ${status === 0 ? `badge bg-primary` : ``}'
                 onclick="ChangeStatus(${id}, 0)">
                 Continue
             </button>
              <button class='status-btn ${status === 1 ? `badge bg-warning text-dark` : ``}'
                 onclick="ChangeStatus(${id}, 1)">
                 Needed
             </button>
             <button class='status-btn ${status === 2 ? `badge bg-success` : ``}'
                 onclick="ChangeStatus(${id}, 2)">
                 Complete
             </button>
             `;
        } else {
            const key = `'${row.DateInput}','${row.DieSerial}', ${row.Total}`;
            actionStatus = `
               <button class='status-btn ${status === 0 ? `badge bg-primary` : ``}'
                   onclick="ChangeDieSerialStatus(${key}, 0)">
                   Continue
               </button>
                <button class='status-btn ${status === 1 ? `badge bg-warning text-dark` : ``}'
                   onclick="ChangeDieSerialStatus(${key}, 1)">
                   Needed
               </button>
               <button class='status-btn ${status === 2 ? `badge bg-success` : ``}'
                   onclick="ChangeDieSerialStatus(${key}, 2)">
                   Complete
               </button>
               `;
        }




        return actionStatus;
    }
    async function ChangeStatus(recordId, status)
    {
        let res = await postMethod('@Url.Action("UpdateDailyStatus", "Mold")',
        { RecordID: recordId, Status: status });
        if (res?.Success) {
            searchByPart()
        }
    }

    async function ChangeDieSerialStatus(dateinput, serial, Total, status) {
        let strdate = normalizeMMDDYY(dateinput);
        let res = await postMethod('@Url.Action("UpdateDailySerialStatus", "Mold")', {
            Datestring: strdate,
            DieSerial: serial,
            Total : Total,
            Status: status
        });
        if (res?.Success) {
            // Refresh your table
            searchByDie();
        }
    }

    /* =========================================================
       DAILY SUMMARY
    ========================================================= */

    async function loadDaily(month = state.currentMonth, day = 0, process = DOM.filterProcess.val()){
        if(state.isYearLoad) await loadYears();

        try {
              const data = {
                  Months: month,
                  Days: day,
                  Year: DOM.yearSelect.val() || state.currentYear,
                  ProcessID: process,
                  pageNumber: state.currentPage || 1,
                  pageSize: state.pageSize || 20
              };
              const res = await GetMethod('@Url.Action("GetMoldDieDailyList","Mold")', data);
              DOM.dailyDisplay.empty();
              if (!res?.Success) return showNoSummaryData();

              state.dailyData = res.Data.Items;
              state.totalRecords = res.Data.TotalRecords || 0;
              state.totalPages = Math.ceil(state.totalRecords / state.pageSize);

             renderDailyTable(state.dailyData);

             updatePaginationUI();
        } catch (e) {
            showNoSummaryData();
        }
    }
    function renderDailyTable(rows) {
        DOM.dailyDisplay.empty();
        rows.forEach(r => {
            DOM.dailyDisplay.append(`<tr>
                <td>${r.DateInput}</td>
                <td><b>${r.PartNo}</b> / ${r.Dimension_Quality}</td>
                <td>${r.CycleShot}</td>
                <td>${r.Total}</td>
                <td>${r.MachineNo}</td>
                <td>${r.Remarks}</td>
                <td>${r.Mincharge}</td>
            </tr>`);
        });
    }

    function renderPartDetails(part) {
        if (!part) return;

        DOM.detailSummary.empty();
        const rowHtml = `
                     <tr>
                         <td>${part.PartNo}</td>
                         <td>${part.Dimension_Quality}</td>
                         <td>${part.DieSerial}</td>
                         <td>${buildStatusBadge(part.Status) }</td>
                     </tr>`;
        DOM.detailSummary.append(rowHtml);
    }

    /* =========================================================
       UTILITIES
    ========================================================= */
   function reloadDailyData() {
        const m = DOM.monthSelect.val();
        const d = DOM.dateInput.val()?.split("-")[2] || 0;
        const p = $("#DailyProcess").val();
        loadDaily(m, d, p);
    }

    function updatePaginationUI() {

        const $pagination = $("#pagination");
        const $paginationItems = $(".pagination-items");

        // Clear existing buttons
        $paginationItems.empty();

        // Always show pagination for debugging
        $pagination.css({
            'display': 'flex',
            'visibility': 'visible',
            'opacity': '1',
            'position': 'relative'
        });

        // Show/hide pagination based on total records
        if (state.totalRecords > state.pageSize) {
            $pagination.show();

            // Create pagination buttons
            const prevDisabled = state.currentPage === 1 ? 'disabled' : '';
            const nextDisabled = state.currentPage === state.totalPages || state.totalPages === 0 ? 'disabled' : '';

            $paginationItems.html(`
              <button class="page-btn prev-btn" ${prevDisabled} data-page="${state.currentPage - 1}">
                  <i class="fas fa-chevron-left"></i> Previous
              </button>

              <div class="page-info">
                  Page ${state.currentPage} of ${state.totalPages || 1}
                  <span class="record-info"></span>
              </div>

              <button class="page-btn next-btn" ${nextDisabled} data-page="${state.currentPage + 1}">
                  Next <i class="fas fa-chevron-right"></i>
              </button>
          `);

            // Add page number input for direct navigation (optional)
            if (state.totalPages > 10) {
                $paginationItems.append(`
                  <div class="page-jump">
                      <input type="number" id="pageJumpInput" min="1" max="${state.totalPages}" value="${state.currentPage}"
                             style="width: 60px; padding: 5px; border: 1px solid #ddd; border-radius: 4px;">
                      <button class="page-btn jump-btn" id="pageJumpBtn">Go</button>
                  </div>
              `);
            }

            // Add click handlers
            $(".page-btn").off('click').on('click', function () {
                if ($(this).is(':disabled')) return;

                const pageNum = parseInt($(this).data('page'));

                if (pageNum >= 1 && pageNum <= state.totalPages && pageNum !== state.currentPage) {
                    state.currentPage = pageNum;
                    loadDaily();
                }
            });

            // Add handler for jump button if exists
            $("#pageJumpBtn").off('click').on('click', function () {
                const jumpPage = parseInt($("#pageJumpInput").val());
                if (jumpPage >= 1 && jumpPage <= state.totalPages && jumpPage !== state.currentPage) {
                    state.currentPage = jumpPage;
                    loadDaily();
                }
            });

            // Add enter key handler for jump input
            $("#pageJumpInput").off('keypress').on('keypress', function (e) {
                if (e.which === 13) { // Enter key
                    $("#pageJumpBtn").click();
                }
            });

        } else {
            $pagination.hide();
        }
    }


    function showNoSummaryData() {
        DOM.dailyDisplay.html(`<tr><td colspan="9">🔍 No Data Found</td></tr>`);
    }

    function showNoData() {
        DOM.tableDisplay.empty();
        DOM.tableDisplay.html(`<tr><td colspan="9">🔍 No Data Found</td></tr>`);
    }

    function buildStatusBadge(status) {
        switch (status) {
            case 0:
                return `<span class="badge bg-primary">Continue</span>`;
            case 1:
                return `<span class="badge bg-warning text-dark">Needed</span>`;
            case 2:
                return `<span class="badge bg-success">Completed</span>`;
            default:
                return `<span class="badge bg-secondary">Unknown</span>`;
        }
    }


    function setDateInput(inputId, dateStr) {
        if (!dateStr) return; // Exit if empty

        const parts = dateStr.split("/"); // ["MM", "DD", "YY"]
        if (parts.length !== 3) return; // Invalid format

        const month = parts[0].padStart(2, '0');
        const day = parts[1].padStart(2, '0');
        const year = "20" + parts[2]; // convert 26 → 2026

        const formattedDate = `${year}-${month}-${day}`;

        const inputElement = document.getElementById(inputId);
        if (inputElement) {
            inputElement.value = formattedDate;
        }
    }

    // normalize MM/dd/YY → YYYY-MM-DD
    function normalizeMMDDYY(dateStr) {
        const [mm, dd, yy] = dateStr.split("/");
        const fullYear = Number(yy) < 50 ? `20${yy}` : `19${yy}`;
        return `${fullYear}-${mm.padStart(2, "0")}-${dd.padStart(2, "0")}`;
    }

    function getStatusHtml(status) {
        if (status === 0) {
            return `
            <button class="status-btn active"
                style="color:#054e92; border:2px solid #054e92;">
                Continue
            </button>`;
        }
        else if (status === 1) {
            return `
            <button class="status-btn pulse-2">
                Needed
            </button>`;
        }
        else if (status === 2) {
            return `
            <button class="status-btn active"
                style="color:#188f18; border:2px solid #188f18;">
                Completed
            </button>`;
        }
        return "";
    }


    async function loadYears(){
        const res = await GetMethod('@Url.Action("GetYearMoldDie","Mold")', {});
        DOM.yearSelect.empty();
        res.forEach(y => DOM.yearSelect.append(`<option value="${y}">${y}</option>`));
        // Set selected value to current year
        DOM.yearSelect.val(state.currentYear);

        state.isYearLoad = false;
    }
</script>