
@{
    ViewBag.Title = "DieMoldMasterlist";
    Layout = "~/Areas/MoldDie/Views/Shared/_MainLayout.cshtml";
}

<section>
    <div class="Mold_ToolHeader flex_space mb-4">

        <div class="flex_align">
            <div class="control-group">
                <label class="control-label">
                    <i class="fas fa-calendar"></i>  Search here
                </label>
                <div class="search-box">
                    <input type="text" placeholder="Search here ... " id="RegisterSearch" />
                </div>
            </div>

            <div class="control-group">
                <label class="control-label">
                    <i class="fas fa-tags"></i> Filter by Description
                </label>
                <select id="DescriptionID" class="filter-select">
                    <option value="">-- Select Description --</option>
                </select>
            </div>

        </div>
        <button class="primarybtn" data-bs-toggle="modal" data-bs-target="#AddTooling"><i class="fa-solid fa-plus"></i> Add Data</button>
    </div>



    <div class="TrackTable" id="DieWrapper">
        <table>
            <thead>
                <tr>
                    <th>PartNo. </th>
                    <th>PartDescription</th>
                    <th id="MonthHeader">Dimension Quality</th>
                    <th>Die Serial</th>
                    <th>DieNumber</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody id="DieMoldToolist">
            </tbody>
        </table>
    </div>


</section>
<div class="pagination" id="pagination">

    <div class="pagination-items">
        <!-- Pagination buttons will be inserted here -->
        <span>asdasda</span>
    </div>
</div>

@Html.Partial("_MasterlistModelForms")



<script type="text/javascript">
    "use strict";
    /* =========================================================
       GLOBAL STATE
    ========================================================= */
    const state = {
        debounceTimer: null,
        totalPages: 0,
        currentPage: 1,
        pageSize: 20,
        totalRecords: 0,
        isFirstLoad: true,
        isYearLoad: true,
        getData: []
    };
    /* =========================================================
       DOM CACHE
    ========================================================= */
    const DOM = {
        DescriptionSelect : $("#DescriptionID"),
        ToolingDisplay : $("#DieMoldToolist"),
        SearchInput: $("#RegisterSearch"),
        descriptSelect: $("#PartDescription"),
        editdescriptSelect: $("#EditPartDescription"),
        Addform : $("#addnewform"),
        Editform : $("#editnewform")
    };
    /* =========================================================
       HELPERS
    ========================================================= */

    /* =========================================================
       INITIALIZATION
    ========================================================= */
    $(document).ready(() => {
        bindEvents();
        GetMoldieDescription();
        GetMoldDieMasterlist();
    });

    /* =========================================================
       EVENT BINDINGS
    ========================================================= */
    function bindEvents() {
        $("#addnewform").on('submit', HandleAddMasterlist);
        $("#editnewform").on('submit', HandleEditMasterlist);

        DOM.SearchInput.on("keyup", () => {
            clearTimeout(state.debounceTimer);
            state.debounceTimer = setTimeout(() => {
                GetMoldDieMasterlist();
            }, 400);
        });

        DOM.ToolingDisplay.on("click", ".EditToolClick", OpenEditMasterModal);
    }
    /* =========================================================
       MASTERLIST PROCESS CRUD OPERATION
    ========================================================= */
    async function HandleAddMasterlist(e){
        e.preventDefault();

        let formData = new FormData(e.target);
        const data = Object.fromEntries(formData);

        // Check for duplicate entry for the same part number on the same date
        let checkduplicate = await GetMethod('@Url.Action("CheckMasterlistMoldExist", "Mold")',
        { PartNo: data.PartNo });

        if (checkduplicate) {
            Swal.fire({
                icon: "error",
                text: `Partnumber ${data.PartNo} is already Exist `,
                timer: 1500,
                showConfirmButton: false
            });
            return;
        }

        let res = await postMethod('@Url.Action("AddMoldDieMasterlist", "Mold")', data);

        if (res?.Success) {
            Swal.fire({
                title: "Success",
                text: res.Message,
                icon: "success",
                confirmButtonColor: "#0d97c9",
                timer: 1500
            }).then(() => {
                GetMoldDieMasterlist();
            });
        } else {
            Swal.fire({
                icon: "error",
                text: res?.Message ?? "Add data Failed",
                timer: 1500,
                showConfirmButton: false
            });
        }
    }

    async function OpenEditMasterModal() {
        const partno = this.id.split("_")[1];
        const row = state.getData.find(r => r.PartNo === partno);
        if (!row) return;

        $("#EditPartNo").val(partno);
        $("#EditPartDescription").val(row.PartDescription);
        $("#EditDimension_Quality").val(row.Dimension_Quality);
        $("#EditDieSerial").val(row.DieSerial);
        $("#EditDieNumber").val(row.DieNumber);
        $("#EditTooling").modal("show");
    }
    async function HandleEditMasterlist(e){
      e.preventDefault();

      let formData = new FormData(e.target);
      const data = Object.fromEntries(formData);

      let res = await postMethod('@Url.Action("UpdateMoldMasterlist", "Mold")', formData);

      if (res?.Success) {
          Swal.fire({
              title: "Success",
              text: res.Message,
              icon: "success",
              confirmButtonColor: "#0d97c9",
              timer: 1500
          }).then(() => {
              GetMoldDieMasterlist();
              $("#EditTooling").modal("hide");
          });
      } else {
          Swal.fire({
              icon: "error",
              text: res?.Message ?? "Update data Failed",
              timer: 1500,
              showConfirmButton: false
          });
      }
  }
    /* =========================================================
       GET MASTERLIST SUMMARY
    ========================================================= */
    async function GetMoldDieMasterlist() {
        try {
            const data = {
                search: DOM.SearchInput.val(),
                filter: DOM.DescriptionSelect.val(),
                page: state.currentPage || 1,
                pageSize: state.pageSize || 20
            };

            const res = await GetMethod('@Url.Action("GetMoldDieMasterList", "Mold")', data);

            if (res?.Success) {
                state.getData = res.Data.Items;
                state.totalRecords = res.Data.TotalRecords || 0;
                state.totalPages = Math.ceil(state.totalRecords / state.pageSize);


                renderMasterlistTable(state.getData);
            }

        } catch (e) {

        }
    }
    function renderMasterlistTable(rows) {
        DOM.ToolingDisplay.empty();
        rows.forEach(r => {
            DOM.ToolingDisplay.append(`<tr>
              <td style='font-weight: 600;'>${r.PartNo}</td>
              <td>${r.PartDescription}</td>
              <td>${r.Dimension_Quality}</td>
              <td>${r.DieSerial}</td>
              <td>${r.DieNumber}</td>
              <td>
                <button type='button' class='btn actionicon text-primary EditToolClick' id='editButton_${r.PartNo}' >
                   <i class='fa-regular fa-pen-to-square action_btn'></i>
                </button>

                <button type="button" class="btn actionicon text-danger deleteDailyButton"
                    id="deleteDailyButton_${r.PartNo}">
                    <i class="fa-regular fa-trash-can"></i>
                </button>
             </td>
          </tr>`);
        });

        updatePaginationUI();

    }

    /* =========================================================
       GET DESCRIPTION LIST
    ========================================================= */
    const GetMoldieDescription = async () => {
        let res = await GetMethod('@Url.Action("GetPartDescription", "Mold")', {});

        DOM.descriptSelect.empty();

        res.forEach(year => {
            DOM.DescriptionSelect.append(`<option value='${year}'>${year}</option>`);
            DOM.descriptSelect.append(`<option value='${year}'>${year}</option>`);
            DOM.editdescriptSelect.append(`<option value='${year}'>${year}</option>`);
        });

        DOM.DescriptionSelect.prop('selectedIndex', 0);
    }




    function updatePaginationUI() {

        const $pagination = $("#pagination");
        const $paginationItems = $(".pagination-items");

        // Clear existing buttons
        $paginationItems.empty();

        // Always show pagination for debugging
        $pagination.css({
            'display': 'flex',
            'visibility': 'visible',
            'opacity': '1',
            'position': 'relative'
        });

        // Show/hide pagination based on total records
        if (state.totalRecords > state.pageSize) {
            $pagination.show();

            // Create pagination buttons
            const prevDisabled = state.currentPage === 1 ? 'disabled' : '';
            const nextDisabled = state.currentPage === state.totalPages || state.totalPages === 0 ? 'disabled' : '';

            $paginationItems.html(`
            <button class="page-btn prev-btn" ${prevDisabled} data-page="${state.currentPage - 1}">
                <i class="fas fa-chevron-left"></i> Previous
            </button>

            <div class="page-info">
                Page ${state.currentPage} of ${state.totalPages || 1}
                <span class="record-info"></span>
            </div>

            <button class="page-btn next-btn" ${nextDisabled} data-page="${state.currentPage + 1}">
                Next <i class="fas fa-chevron-right"></i>
            </button>
        `);

            // Add page number input for direct navigation (optional)
            if (state.totalPages > 10) {
                $paginationItems.append(`
                <div class="page-jump">
                    <input type="number" id="pageJumpInput" min="1" max="${state.totalPages}" value="${state.currentPage}"
                           style="width: 60px; padding: 5px; border: 1px solid #ddd; border-radius: 4px;">
                    <button class="page-btn jump-btn" id="pageJumpBtn">Go</button>
                </div>
            `);
            }

            // Add click handlers
            $(".page-btn").off('click').on('click', function () {
                if ($(this).is(':disabled')) return;

                const pageNum = parseInt($(this).data('page'));

                if (pageNum >= 1 && pageNum <= state.totalPages && pageNum !== state.currentPage) {
                    state.currentPage = pageNum;
                    GetMoldDieMasterlist();
                }
            });

            // Add handler for jump button if exists
            $("#pageJumpBtn").off('click').on('click', function () {
                const jumpPage = parseInt($("#pageJumpInput").val());
                if (jumpPage >= 1 && jumpPage <= state.totalPages && jumpPage !== state.currentPage) {
                    state.currentPage = jumpPage;
                    GetMoldDieMasterlist();
                }
            });

            // Add enter key handler for jump input
            $("#pageJumpInput").off('keypress').on('keypress', function (e) {
                if (e.which === 13) { // Enter key
                    $("#pageJumpBtn").click();
                }
            });

        } else {
            $pagination.hide();
        }
    }
</script>