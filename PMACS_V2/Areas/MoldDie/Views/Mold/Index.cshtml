
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="@Url.Content("~/Content/Images/pmacs.ico")">
    <link rel="preload" href="@Url.Content("~/Content/fonts/Poppins-Regular.ttf")" as="font" type="font/ttf" crossorigin="anonymous">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mold Die and Cavity Parts Management System</title>

    <script src="~/Scripts/Shared/bootstrap.bundle.min.js"></script>


    @Styles.Render("~/Content/shared-css")
    @Styles.Render("~/Content/pmacs-css")


    @Scripts.Render("~/bundles/shared-js")
    @Scripts.Render("~/bundles/modernizr")
</head>
<section class="main flex_center">
    <div class="main__container">
        <!----------- login background design -------->
        <div class="main__contain">

            <h1 style="line-height: 1.6;">
                Mold Die and Cavity Parts Management System
            </h1>
        </div>
        <div class="main__contain">
            <img src="~/Content/Images/forgotpass.png" width="300" height="300" />
        </div>

        <div class="formbox">
            <div class="form signform">
                <form method="post" id="loginsubmit" class="logindesign">
                    <div class="logindesign__contain">
                        <h2 style="font-weight: 600; margin-top: 1em; font-size: 1.5rem;"> Welcome, User</h2>
                        <p>Enter your credentials</p>

                        <div class="logindesign__label">
                            <label style="font-weight: 600;">Full Name:</label>
                            <span class="text-danger" id="erroruser"></span>
                        </div>
                        <div class="search-box">
                            <input type="text" name="username" id="username" autocomplete="off" placeholder="Enter fullname">
                            <div class="namesdisplay"></div>
                        </div>
                        <div class="logindesign__label">
                            <label style="font-weight: 600;">Password : </label>
                            <span class="text-danger" id="errorpass"></span>
                        </div>
                        <input type="password" name="password" id="password" autocomplete="new-password" placeholder="Enter your password">


                        <div id="error-msg" style="color: red;"></div>
                        <button style="width: 100%; margin-top: 1em; padding: 1em 0;" class="submitbtn" id="submitbtn" type="submit"><span class="flex_align"><i class="fa-solid fa-right-to-bracket"></i> Login</span></button>
                        <div class="formbox__action">
                            @*<button type="button" id="viewbtn"><i class="fa-regular fa-eye"></i> View Only</button>*@

                        </div>

                        <div Class="footer">
                            <small>Forgot password ? <a href="#" class="signin">Click here</a></small>
                        </div>
                    </div>
                </form>
            </div>


            <div class="form forgetform">
                <form id="forgetform" class="forgetdesign">
                    @*<button class="forgetbtn"><i class="fa fa-arrow-left" aria-hidden="true"></i></button>*@

                    <h2 style="font-weight: 600; font-size: 1.5rem;"> Forgot Password ?</h2>
                    <p style="line-height: 1.6; margin-bottom: 1em;">We'll help you reset your password </p>
                    <Label>Username:</Label>
                    <input type="text" placeholder="Enter your username" id="changeuser" name="changeuser" required>
                    <Label>Employee ID:</Label>
                    <input type="text" placeholder="Enter your Employee ID" id="changeEmpID" name="changeEmpID" required>
                    <Label>New password :</Label>
                    <input type="text" placeholder="Enter your new password" id="changepass" name="changepass" required>


                    @*<button type="submit" class="newpassbtn" id="newpassbtn"><i class="fa-solid fa-paper-plane"></i> Submit</button>*@
                    <div class="forgetfooter flex_align">
                        <button type="button" id="forgetviewbtn" class="backlogs"><i class="fa fa-arrow-left" aria-hidden="true"></i>Back</button>
                        <button type="submit" class="newpassbtn" id="newpassbtn"><span class="flex_align"><i class="fa-solid fa-paper-plane"></i> Submit</span></button>
                    </div>
                </form>
            </div>
        </div>


    </div>
    <footer Class="main__credits">
        <span>© 2024 P1SA - Process Control All rights reserved.</span>

    </footer>
</section>

<div id="notification" class="notification">
    <div class="notification-container">
        <div class="notification-header">
            <h2>System Update</h2>
        </div>
        <div class="notification-content">
            <div class="notification-version">
                <h3>New Features:</h3>
                <p>Version @ViewData["Version"]</p>
            </div>
            <ul id="features-list">
                <li>1. Automatic login on first access</li>
                <li>2. System automatically logs out after 24 hours</li>
                <li>3. UI update for Manpower Production</li>
                <li>4. Updated view style for Capacity per Process</li>
            </ul>

            <div class="notification-footer flex_center mt-3">
                <button id="close-btn">Close</button>
            </div>
        </div>
    </div>
</div>

<script type="module" asp-append-version="true">
    import {
        getMethod,
        postMethod,
        getMethodPublic
    } from  '@Url.Content("~/Scripts/modules/index.js")';

    class Logincontroller{
        constructor() {
            this.version = "@ViewData["Version"]";
            this.loadData = [];

            this.mainbody = document.querySelector(".main");
            this.forbtn = document.querySelector(".backlogs");
            this.resultBox = document.querySelector(".namesdisplay");
            this.inputbox = document.getElementById("username");

            // FORMS 
            this.logbtn = document.querySelector(".signin");
            this.loginforms = document.getElementById('loginsubmit');

            this.inputfield = document.getElementById("password");

            this.submitBtn = document.getElementById("submitbtn");

            this.init();
        }

        async init() {
            this.bindEvents();
            await this.loadPageData();
        }

        bindEvents() {
            // Slide animation
            this.logBtn?.addEventListener("click", () => {
                this.mainBody.classList.add("slide");
            });

            this.forBtn?.addEventListener("click", () => {
                this.mainBody.classList.remove("slide");
            });

            // Autocomplete
            this.inputbox?.addEventListener("keyup", (e) => {
                this.handleSearch(e.target.value);
            });

            // Enter key login
            this.passwordField?.addEventListener("keydown", (e) => {
                if (e.key === "Enter") {
                    e.preventDefault();
                    this.handleLogin(new FormData(this.loginforms));
                }
            });

            // Submit login
            this.loginforms?.addEventListener("submit", (e) => {
                e.preventDefault();
                this.handleLogin(new FormData(this.loginforms));
            });
        }


        /* ================= LOAD DATA ================= */

        async loadUsers() {
            const res = await getMethodPublic('/PMACS/GetFullnameList', {});
            if (res?.Success) {
                this.loadData = res.Data.map(x => x.Fullname);
            }
        }

        loadUpdates() {
            const storedVersion = localStorage.getItem('systemVersion');

            if (storedVersion !== this.version) {
                const notification = document.getElementById('notification');
                notification.style.display = 'flex';
                localStorage.setItem('systemVersion', this.version);
            }

            document.getElementById('close-btn')?.addEventListener('click', () => {
                document.getElementById('notification').style.display = 'none';
            });
        }

        async loadPageData() {
            try {
                //this.inputBox.value = "";
                //this.passwordField.value = "";

                //await Promise.all([
                   
                //]);
                await this.loadUsers();
            } catch (err) {
                console.error("Load error:", err);
            }
        }

        /* ================= AUTOCOMPLETE ================= */

        handleSearch(value) {
            if (!value.length) {
                this.resultBox.style.display = "none";
                return;
            }

            const result = this.loadData.filter(name =>
                name.toLowerCase().includes(value.toLowerCase())
            );

            if (!result.length) {
                this.resultBox.style.display = "none";
                return;
            }

            this.renderResults(result);
        }

        renderResults(list) {
            this.resultBox.style.display = "block";
            this.resultBox.innerHTML = `
            <ul>
                ${list.map(name => `<li data-name="${name}">${name}</li>`).join("")}
            </ul>
        `;

            this.resultBox.querySelectorAll("li").forEach(li => {
                li.addEventListener("click", () => {
                    console.log("Click Display" + li.dataset.name)
                    this.inputbox.value = li.dataset.name;
                    this.resultBox.innerHTML = "";
                    this.resultBox.style.display = "none";
                });
            });
        }

        /* ================= LOGIN ================= */

        async handleLogin(formData) {
            //if (!this.validateForm()) return;

            const data = Object.fromEntries(formData);
            formData.append('proj', 2);

            this.submitBtn.innerHTML = `<div class='buttonloading'></div>`;

            const res = await postMethodPublic('/Auth/Authenticate', formData);

            if (res?.Success) {
                this.loginSuccess(res);
            } else {
                this.loginError(res?.Message);
            }
        }

        loginSuccess(res) {
            // Storage
            localStorage.setItem('UserRole', res.Data.role);
            localStorage.setItem('Fullname', res.Data.fullname);
            localStorage.setItem('accessToken', res.Data.access_token);
            localStorage.setItem('refreshToken', res.Data.refresh_token);
            localStorage.setItem('loginTime', new Date().toISOString());
            localStorage.setItem('isLoggedInPMACS', 'true');

            window.location.href = "/MoldDie/Mold/DieMoldSummary";

            //Swal.fire({
            //    title: "Success",
            //    text: res.Message,
            //    icon: "success",
            //    showConfirmButton: false,
            //    timer: 1500
            //}).then(() => {

                
            //});
        }

        loginError(message) {
            //Swal.fire({
            //    icon: "error",
            //    text: message || "Login failed",
            //    timer: 1500,
            //    showConfirmButton: false
            //});
            this.submitBtn.innerHTML =
                `<span class='textload'><i class='fa-solid fa-right-to-bracket'></i> Login</span>`;
        }

        validateForm() {
            const user = this.inputBox.value.trim();
            const pass = this.passwordField.value.trim();

            const errorUser = document.getElementById("erroruser");
            const errorPass = document.getElementById("errorpass");

            errorUser.textContent = "";
            errorPass.textContent = "";

            if (!user) {
                errorUser.textContent = "Please enter your Fullname";
                return false;
            }

            if (!pass) {
                errorPass.textContent = "Please enter your password";
                return false;
            }

            return true;
        }
    }

    /* ================= INIT ================= */

    document.addEventListener("DOMContentLoaded", () => {
        new Logincontroller();
    });
   
</script>



