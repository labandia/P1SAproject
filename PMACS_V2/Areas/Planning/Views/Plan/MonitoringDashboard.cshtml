            lacking: document.getElementById('lackingContent'),
            materialProb: document.getElementById('materialProbContent'),
            monthly: document.getElementById('monthlyContent')
        };

        function activateTab(tabId) {
            // Remove active class from all contents
            Object.values(contents).forEach(content => {
                if (content) content.classList.remove('active-tab');
            });
            // Add active class to selected content
            if (contents[tabId]) contents[tabId].classList.add('active-tab');

            // Update nav active styling
            tabs.forEach(tab => {
                const tabValue = tab.getAttribute('data-tab');
                if (tabValue === tabId) {
                    tab.classList.add('active');
                } else {
                    tab.classList.remove('active');
                }
            });
        }

        // Add click listeners
        tabs.forEach(tab => {
            tab.addEventListener('click', (e) => {
                const tabId = tab.getAttribute('data-tab');
                if (tabId) activateTab(tabId);
            });
        });

        // Ensure third tab is active by default (matching initial active class)
        const defaultActive = document.querySelector('.nav-tab.active');
        if (defaultActive) {
            const defaultTab = defaultActive.getAttribute('data-tab');
            if (defaultTab && contents[defaultTab]) {
                activateTab(defaultTab);
            } else {
                activateTab('materialProb');
            }
        } else {
            activateTab('materialProb');
        }
    })();
</script>