        async init() {
            await this.LoadActiveShopOrders();
            this.refreshInterval = setInterval(
                () => this.LoadActiveShopOrders(),
                30000
            );

             // add reset button listener
            const resetBtn = document.getElementById('resetGridBtn');
            if (resetBtn) {
                resetBtn.addEventListener('click', () => this.resetToGrid());
            }
        }


        /* ================= LOAD DATA ================= */
         async LoadActiveShopOrders() {
            if (this.isAnimating) return;

            try {
                const res = await getMethod('@Url.Action("GetListActiveShopOrders", "Assembly")', {});

                if (!res?.Success) {
                    if (!this.isExpanded) this.RenderEmptyState();
                    return;
                }

                const apiData = res.data ?? [];

                if (apiData.length === 0) {
                    this.allCardsData = [];
                    if (!this.isExpanded) this.RenderEmptyState();
                    return;
                }

                const lookup = new Map(apiData.map(item => [item.Line, item]));
                const records = this.assemblyRecords.map(res => {
                    const fromApi = lookup.get(res.Line);
                    return {
                        Line: res.Line,
                        FinalShopOrder: "",
                        Model: "",
                        CompletedSection: "",
                        NextItem: "",
                        Note: "",
                        OrderRemarks: "",
                        RecordID: null,     // add
                        PlanQty: 0,         // add
                        InputQty: 0,        // add
                        ...(fromApi ?? {})
                    };
                });
                this.allCardsData = records; // store for potential reset
                if (this.isExpanded && this.currentCenteredCard && this.activeLineId) {
                    // Update modal content with fresh data for this line
                    const updatedRecord = records.find(r => r.Line === this.activeLineId);
                    this.prevModelprocess = updatedRecord.NextItem;
                    if (updatedRecord) {
                        this.updateModalContent(updatedRecord, { animateNextModel: true });
                    }
                } else {
                    // Normal full render
                    this.RenderCardList(records);
                }
            } catch (err) {
                console.error(err);
            }
        }


        /* ========== TYPING ANIMATION ========== */
        async typeText(element, text, speed = 10, loop = false) {
            if (this._typingAbort) {
                this._typingAbort();
                this._typingAbort = null;
            }

            if (!element) return;

            const displayText = text || "-";
            if (displayText === "-" || displayText.length <= 1) {
                element.textContent = displayText;
                element.classList.remove('typing-cursor');
                element.classList.add('typing-done');
                return;
            }

            let cancelled = false;
            const abort = () => { cancelled = true; };
            this._typingAbort = abort;

            const runTyping = async () => {
                if (cancelled) return;
                element.textContent = "";
                element.classList.add('typing-cursor');
                element.classList.remove('typing-done');

                const chars = displayText.split("");
                for (let i = 0; i < chars.length; i++) {
                    if (cancelled) {
                        element.textContent = displayText;
                        element.classList.remove('typing-cursor');
                        element.classList.add('typing-done');
                        return;
                    }
                    element.textContent += chars[i];
                    let delay = speed;
                    if (chars[i] === "." || chars[i] === "," || chars[i] === "!" || chars[i] === "?") {
                        delay = speed * 2.5;
                    } else if (chars[i] === " ") {
                        delay = speed * 0.6;
                    }
                    await new Promise(r => setTimeout(r, delay));
                }

                // finished typing
                element.classList.remove('typing-cursor');
                element.classList.add('typing-done');

                // loop if requested and not cancelled
                if (loop && !cancelled) {
                    await new Promise(r => setTimeout(r, 2000)); // pause before restart
                    if (!cancelled) {
                        runTyping(); // restart
                    }
                }
            };

            runTyping();
        }




        updateModalContent(item, options = {}) {
            const { animateNextModel = false } = options;
            if (!this.currentCenteredCard) return;

            const sectionMap = {
                1: ['badge-molding', 'AG'],
                2: ['badge-press', 'AF'],
                3: ['badge-rotor', 'BF'],
                4: ['badge-winding', 'FA'],
                5: ['badge-circuit', 'CE'],
                7: ['badge-harness', 'FG'],
                9: ['badge-Material', 'DD']
