                    <p class="card-footer-label" style='font-size: 1.1rem;'>Remarks</p>
                    <p class="card-footer-value" style='font-size: 1.2rem;'>${item.OrderRemarks || '-'}</p>
                </div>
            </div>


            <div  style="display:flex;align-items:center;gap:8px; justify-content: space-between; margin-top: 4em;">
                <div>
                    <small>Quantity:</small>
             <input type="number" id="modalQtyInput" class="completed-qty"
                    min="1" max="${item.PlanQty || 0}" value="${item.InputQty === 0 ? '' : item.InputQty}" />
                      <span> / ${item.PlanQty || 0}</span>

                </div>

                
                <div style="display:flex; align-items:center; gap: 10px;">
                     <button type="button" id="modalCancel" class="btn-cancel" ${item.InputQty !== 0 ? 'disabled' : ''}><iconify-icon icon="mdi-light:cancel" width="16"></iconify-icon>  Cancel</button>

                    <button type="button" id="modalCompleteBtn" class="btn-completed"
                            data-line="${item.Line}" data-order="${item.FinalShopOrder}"><iconify-icon icon="fluent-mdl2:completed" width="15"></iconify-icon>  Completed</button>
                </div>

            </div>
        </div>
    `;

    // Close button listener
    const closeBtn = this.currentCenteredCard.querySelector('#closeCenteredBtn');
    if (closeBtn) closeBtn.addEventListener('click', () => this.resetToGrid());

    // Editable quantity input (blur event)
    const qtyInput = this.currentCenteredCard.querySelector('#modalQtyInput');
    if (qtyInput) {
         const updateQty = async (value) => {
            const newQty = parseInt(value || 0);

            if (!newQty || newQty === item.InputQty) return;

            if (newQty > item.PlanQty) {
                qtyInput.value = item.InputQty;
                return;
            }

            try {
                await postMethod('@Url.Action("UpdateQuantityLine", "Assembly")', {
                    recordID: item.RecordID,
                    Qty: newQty
                });

                await this.LoadActiveShopOrders();
            } catch (err) {
                console.error(err);
            }
        };

        // Blur
        qtyInput.addEventListener('blur', async (e) => {
            await updateQty(e.target.value);
        });

        // Enter key
        qtyInput.addEventListener('keydown', async (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                qtyInput.blur(); // optional: remove focus
                await updateQty(e.target.value);
            }
        });
    }

    // Active Completed button
    const completeBtn = this.currentCenteredCard.querySelector('#modalCompleteBtn');
    if (completeBtn) {
        // Update the row Data into a Complete
        completeBtn.addEventListener('click', async (e) => {
            e.stopPropagation();
            const res = await postMethod('@Url.Action("CompleteStatusLine", "Assembly")', {
                recordID: item.RecordID,
                line: item.Line
            });
            if (!res?.Success) return;

            // 2. Loads the Latest Load Active ShopOrder (Online)
            await this.LoadActiveShopOrders();

            // 4. If there is NO next process (empty or null), close the modal
            if (this.prevModelprocess === "") {
                await this.resetToGrid();
            }

            this.prevModelprocess = "";
        });
    }

    // Cancel  button
    const cancelbtn = this.currentCenteredCard.querySelector('#modalCancel');
    if (cancelbtn) {
        cancelbtn.addEventListener('click', async (e) => {
            e.stopPropagation();
            alert("Cancel Inprocess");
            //let res = await this.updateOrderStatus(item.RecordID, 0, item.Line);
          
         });
