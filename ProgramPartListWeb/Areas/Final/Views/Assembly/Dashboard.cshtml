                    `;
                }

                // Only click event to open modal (no input/button listeners)
                card.addEventListener('click', async (e) => {
                    if (this.isExpanded || this.isAnimating) return;

                    if (!isOnline) {

                        const res = await getMethod('@Url.Action("GetCountRecords", "Assembly")', { line: item.Line });
                        if (!res.Success) return;

                        if (res.data != 0) {
                            window.location.href = '@Url.Action("ShopOrderLine", "Assembly")?Line=' + encodeURIComponent(item.Line);
                        }

                       return;
                    }
                    this.prevModelprocess = item.NextItem;
                    await this.animateCardToCenter(card, item);
                });

                fragment.appendChild(card);
            });

            gridContainer.innerHTML = '';
            gridContainer.appendChild(fragment);
}


       async animateCardToCenter(cardElement, itemData) {
            if (this.isExpanded || this.isAnimating) return;
            this.isAnimating = true;
            this.activeLineId = itemData.Line;
            this.originalCard = cardElement;

            // 1. Create backdrop immediately
            let backdrop = document.querySelector('.animation-backdrop');
            if (!backdrop) {
                backdrop = document.createElement('div');
                backdrop.className = 'animation-backdrop';
                document.body.appendChild(backdrop);
            }
            backdrop.classList.add('active');

            // 2. Disable grid clicks
            const grid = document.getElementById('assemblyCardsGrid');
            grid.classList.add('disabled-grid');

            // 3. Get original card rect
            const rect = cardElement.getBoundingClientRect();
            const startWidth = rect.width;
            const startHeight = rect.height;
            const startLeft = rect.left;
            const startTop = rect.top;

            // 4. Create clone and position it exactly over original
            const clone = cardElement.cloneNode(true);
            clone.classList.add('floating-card-clone');
            clone.style.position = 'fixed';
            clone.style.top = `${startTop}px`;
            clone.style.left = `${startLeft}px`;
            clone.style.width = `${startWidth}px`;
            clone.style.height = `${startHeight}px`;
            clone.style.borderRadius = getComputedStyle(cardElement).borderRadius;
            clone.style.padding = getComputedStyle(cardElement).padding;
            clone.style.margin = '0';
            clone.style.boxShadow = '0 30px 45px rgba(0,0,0,0.25)';
            clone.style.background = getComputedStyle(cardElement).background;
            clone.style.pointerEvents = 'none';
            document.body.appendChild(clone);
            this.cloneCard = clone;

            // 5. Hide the original card (visibility hidden or opacity 0)
            cardElement.style.opacity = '0';
            cardElement.style.visibility = 'hidden'; // keep layout
            cardElement.style.pointerEvents = 'none';

            // 6. Simultaneously fade out other cards (but don't remove yet)
            const allCards = Array.from(grid.querySelectorAll('.line-card'));
            const otherCards = allCards.filter(c => c !== cardElement);
            otherCards.forEach(c => {
                c.style.transition = 'opacity 0.2s ease, transform 0.2s ease';
                c.style.opacity = '0';
                c.style.transform = 'scale(0.95)';
                c.style.pointerEvents = 'none';
            });

            // 7. Target center dimensions
            const targetWidth = Math.min(640, window.innerWidth * 0.85);
            const targetHeight = 550;
            const targetLeft = (window.innerWidth - targetWidth) / 2;
            const targetTop = (window.innerHeight - targetHeight) / 2;

            // 8. Start clone animation
            const keyframes = [
                {
                    top: `${startTop}px`,
                    left: `${startLeft}px`,
                    width: `${startWidth}px`,
                    height: `${startHeight}px`,
                    borderRadius: getComputedStyle(cardElement).borderRadius,
                },
                {
                    top: `${targetTop}px`,
                    left: `${targetLeft}px`,
                    width: `${targetWidth}px`,
                    height: `${targetHeight}px`,
                    borderRadius: '36px',
                }
            ];
            const animation = clone.animate(keyframes, {
                duration: 500,
                easing: 'cubic-bezier(0.2, 0.95, 0.4, 1.05)',
                fill: 'forwards'
            });

            // 9. Wait for animation to finish
            await animation.finished;

            // 10. Remove clone
            if (this.cloneCard && this.cloneCard.parentNode) this.cloneCard.remove();
            this.cloneCard = null;

            // 11. Remove original card and other cards from DOM
            cardElement.remove();
            otherCards.forEach(c => c.remove());

            // 12. Create final centered card
            this.createCenteredCard(itemData, targetLeft, targetTop, targetWidth, targetHeight);

            this.isAnimating = false;
            this.isExpanded = true;
        }

        createCenteredCard(data, left, top, width, height) {
            if (this.currentCenteredCard) this.currentCenteredCard.remove();
            const centeredDiv = document.createElement('div');
            centeredDiv.className = 'centered-standalone-card';
            centeredDiv.style.left = `${left}px`;
            centeredDiv.style.top = `${top}px`;
            centeredDiv.style.width = `${width}px`;
            centeredDiv.style.height = `${height}px`;
            centeredDiv.style.overflowY = 'auto';
            this.currentCenteredCard = centeredDiv;
            this.updateModalContent(data, { animateNextModel: true });
            document.body.appendChild(centeredDiv);
        }

        async resetToGrid() {
            if (!this.isExpanded || this.isAnimating) return;
            this.isAnimating = true;

            if (this.currentCenteredCard) {
                this.currentCenteredCard.remove();
                this.currentCenteredCard = null;
            }
            const backdrop = document.querySelector('.animation-backdrop');
            if (backdrop) backdrop.classList.remove('active');

            const grid = document.getElementById('assemblyCardsGrid');
            if (grid) grid.classList.remove('disabled-grid');

            this.isExpanded = false;
            this.isAnimating = false;
            this.activeLineId = null;
            await this.LoadActiveShopOrders();
        }

        RenderEmptyState() {
                const gridContainer = document.getElementById('assemblyCardsGrid');
                if (!gridContainer) return;
                if (this.isExpanded) return;

                const fragment = document.createDocumentFragment();

                this.assemblyRecords.forEach((item, index) => {
                    const card = document.createElement('div');
                    card.className = 'line-card line-card-offline';
                    card.dataset.Line = item.Line;

                    card.style.setProperty('--order', index);
                    card.classList.add('stagger-in');

                    card.innerHTML = `
                        <div class="card-header">
                            <div class="line-badge">
                                <div class="line-id line-id-offline">${item.Line}</div>
                                <span class="status-tag status-tag-offline">Offline</span>
                            </div>
                            <span class="production-note">No production</span>
                        </div>

                        <div class="idle-center">
                            <div class="pause-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M10 15V9m4 6V9"/></svg></div>
                            <div class="idle-title">No Active Model Process</div>
                            <div class="idle-sub">No  Next process Model found. Please Update the Data Inside </div>
                        </div>
                    `;

                    // Click event for offline cards
                    card.addEventListener('click', async (e) => {
                        if (this.isExpanded || this.isAnimating) return;
                         window.location.href = '@Url.Action("ShopOrderLine", "Assembly")?Line=' + encodeURIComponent(item.Line);
                        @*const res = await getMethod('@Url.Action("GetCountRecords", "Assembly")', { line: item.Line });
                        console.log(res);*@
                    });

                    fragment.appendChild(card);
                });

                gridContainer.innerHTML = '';
                gridContainer.appendChild(fragment);
            }

        buildOfflineCardHTML(line) {
            return `
                <div class="card-header">
                    <div class="line-badge">
                        <div class="line-id line-id-offline">${line}</div>
                        <span class="status-tag status-tag-offline">Offline</span>
                    </div>
                    <span class="production-note">No production</span>
                </div>
                <div class="idle-center">
                    <div class="pause-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M10 15V9m4 6V9"/></svg></div>
                    <div class="idle-title">No Active Model Process</div>
                    <div class="idle-sub">No Next process Model found. Please Update the Data Inside</div>
                </div>
            `;
        }

        updateLastRefresh() {
            const span = document.getElementById('lastUpdated');
            if (span) {
                const now = new Date();
                const timeStr = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
                span.innerText = `Auto-refresh every 30s · Last updated ${timeStr}`;
            }
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        const controller = new FinalAssemblyController();
        controller.init();
    });
</script>
