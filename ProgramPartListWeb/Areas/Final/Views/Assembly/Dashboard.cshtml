    this.currentCenteredCard.addEventListener('dblclick', (e) => {
        // Prevent navigation if clicking on input, button, or close button
        if (e.target.closest('input') || e.target.closest('button')) return;
        localStorage.setItem("LineSet", item.Line);
        window.location.href = '@Url.Action("ShopOrderLine", "Assembly")?Line=' + encodeURIComponent(item.Line);
    });


    // --- handle next model text animation ---
    const nextModelEl = this.currentCenteredCard.querySelector('.next-model-text');
        if (nextModelEl) {
            if (animateNextModel) {
                this.typeText(nextModelEl, item.NextItem || '-', 50);
            } else {
                nextModelEl.textContent = item.NextItem || '-';
                nextModelEl.classList.remove('typing-cursor');
                nextModelEl.classList.add('typing-done');
            }
        }

    }




     RenderCardList(data) {
        const gridContainer = document.getElementById('assemblyCardsGrid');
        if (!gridContainer) return;
        if (this.isExpanded) return;

         const sectionMap = {
             1: ['badge-molding', 'AG'],
             2: ['badge-press', 'AF'],
             3: ['badge-rotor', 'BF'],
             4: ['badge-winding', 'FA'],
             5: ['badge-circuit', 'CE'],
             7: ['badge-harness', 'FG'],
             9: ['badge-Material', 'DD']
         };

        const fragment = document.createDocumentFragment();

        data.forEach((item, index) => {
                const shopOrder = (item.FinalShopOrder ?? '').trim();
                const isOnline = shopOrder !== '';
                const card = document.createElement('div');
                card.className = 'line-card' + (isOnline ? ' line-card-online' : ' line-card-offline');
                card.dataset.Line = item.Line;

                 // set custom property for stagger delay
                card.style.setProperty('--order', index);
                // add stagger-in class to trigger animation
                card.classList.add('stagger-in');

                if (!isOnline) {
                    card.innerHTML = `
                        <div class="card-header">
                            <div class="line-badge">
                             <div class="line-id line-id-offline">${item.Line}</div>
                               <span class="status-tag status-tag-offline">Offline</span>
                            </div>
                            <span class="production-note">No production</span>
                          </div>

                        <div class="idle-center">
                            <div class="pause-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M10 15V9m4 6V9"/></svg></div>
                            <div class="idle-title">No Active Model Process</div>
                            <div class="idle-sub">No  Next process Model found. Please Update the Data Inside </div>
                          </div>

                    `;
                } else {
                    const completedSections = (item.CompletedSection || '')
                        .split(',')
                        .map(x => x.trim())
                        .filter(x => sectionMap[x]);
                    const completionPct = Math.round((completedSections.length / 6) * 100);
                    const badges = completedSections
                        .map(x => {
                            const [css, text] = sectionMap[x];
                            return `<span class="status-badge ${css}">${text}</span>`;
                        })
                        .join('');
                    console.log(item.NextItem);
                    // Grid card: READONLY input and DISABLED button
                    let badgeopen = (item.NextItem != null && item.NextItem !== "")
                        ? `<div class="badge-row">${badges}</div>`
                        : '-';
                  

                    card.innerHTML = `

                        <div class="card-header">
                            <div class="card-header-left">
                                <div class="line-id line-id-online">${item.Line}</div>
                                <span class="status-tag status-tag-online">
                                    <div class="dot-indicator"></div> Online
                                </span>
                            </div>
                            <div class="card-complete-area" style="display:flex;align-items:center;gap:8px;">
                                <div>
                                  <span><strong>${item.InputQty === 0 ? '0' : item.InputQty}</strong>  / ${item.PlanQty || 0}</span>
                                </div>
                            </div>
                        </div>

                        <div class="card-row" style=' margin: .5em 0;'>
                            <p class="card-row-label">On Process Model</p>
                            <p class="card-row-value">${item.Model || '-'}</p>
                        </div>
                        <div class="card-row" style=' margin: .5em 0;'>
                            <p class="card-row-label" style="margin-bottom:8px">
                                Material Status : <span class="card-row-label">${completionPct}%</span>
                            </p>
                            ${badgeopen}
                        </div>
                        <div class="card-row" style=' margin: .5em 0;'>
                            <p class="card-row-label">Next Process Model</p>
                            <p class="card-row-value-normal">${item.NextItem || '-'}</p>
                        </div>
                        <div class="card-footer">
                            <div class="card-footer-col">
                                <p class="card-footer-label">Special Process</p>
                                <p class="card-footer-value">${item.Note || '-'}</p>
                            </div>
                            <div class="card-footer-col">
                                <p class="card-footer-label">Remarks</p>
                                <p class="card-footer-value">${item.OrderRemarks || '-'}</p>
                            </div>
