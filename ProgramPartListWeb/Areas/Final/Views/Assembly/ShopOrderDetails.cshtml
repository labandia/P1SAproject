                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Part No</span>
                        <span class="detail-value" id="partnoText">00454139-01</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Model</span>
                        <span class="detail-value" style="font-family:var(--font-mono)" id="ModelText">9A0612G4D031-3P, SDC FC</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Quantity</span>
                        <span class="detail-value" id="QuanText">400</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label" >Line</span>
                        <span class="detail-value" id="LineText">OP</span>
                    </div>
                </div>
