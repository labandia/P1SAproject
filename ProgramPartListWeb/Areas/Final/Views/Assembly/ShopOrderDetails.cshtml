    </div>

    <!-- Right Panel -->
    <div class="right-panel">
        <div class="panel-header">
            <div class="panel-header-line"></div>
            <span class="panel-header-title">Assembly Status</span>
        </div>

        <form method="post" id="EditFinalAsembly" class="panel-content">
            <div class="field-group">
                <span class="field-label">Final Assembly Status</span>
               <input  type="text" class="field-box" placeholder="Enter Final Assembly Status" id="FAStatus"/>
            </div>
            <div class="field-group">
                <span class="field-label">Shipment Date</span>
                <input type="date" class="field-box" placeholder="Enter Final Assembly Status" id="ShipmentDate" />
            </div>
            @*<div class="field-group">
                <span class="field-label">Mode</span>
                <input type="text" placeholder="Enter Final Assembly Status" id="ShipmentMode" />
            </div>*@
        <div class="check-group">
            <span class="field-label">With SR : </span>
            <input type="checkbox" id="WithSR" />
        </div>
            <div class="field-group">
                <span class="field-label">Remarks</span>
                <textarea class="textarea-box"  placeholder="Enter Remarks" id="Remarks" > </textarea>
            </div>
            <button class="save-btn">
                <span class="icon-inline" style="width:13px;height:13px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8"><path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z" /><path d="M17 21v-7a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v7M7 3v4a1 1 0 0 0 1 1h7" /></svg>
                    </span> Save Changes</button>
        </form>
  
    </div>
</div>




<script type="module" asp-append-version="true">
    import {
        getMethod,
        postMethod
    } from '@Url.Content("~/Scripts/modules/index.js")';

    class ShopOrderDetailsController {
        constructor() {
            this.tbody = document.querySelector('.devices-table tbody');
            this.recordID = document.getElementById('intID').value;
            this.strLine = "";
            this.intRecord = 0;
            //this.navget = document.getElementById('navcont');
        }

        async init() {
            await this.LoadDetailsinfo();
            this.bindEvents();
        }

        bindEvents() {
            @*this.navget.addEventListener('click', (e) => {
                e.preventDefault();
                window.location.href = `@Url.Action("ShopOrderLine", "Assembly")?Line=${this.strLine}`;
            });*@

            const form = document.getElementById('EditFinalAsembly');
            form.addEventListener('submit', (e) => this.HandleSubmit(e));
        }

        async LoadDetailsinfo() {
            try {
                const res = await getMethod('@Url.Action("SelectedShopOrderData", "Assembly")', {
                    RecordID: this.recordID
                });
                if (!res?.Success) return;
                const data = res.data;
                this.strLine = data.Line;
                console.log(data);
                document.getElementById("finalShopOrderText").textContent = data.FinalShopOrder;
                document.getElementById("partnoText").textContent = data.ItemNo;
                document.getElementById("ModelText").textContent = data.Model;
                document.getElementById("QuanText").textContent = data.PlanQty;
                document.getElementById("LineText").textContent = data.Line;

                document.getElementById("PlanText").textContent = data.PlanQty;
                document.getElementById("DispatchText").textContent = data.DispatchDate;
                document.getElementById("WCText").textContent = data.WC;
                document.getElementById("IFSText").textContent = this.formatDate(data.FinalFinishedDate);
                document.getElementById('WithSR').checked = data.WithSR;

                //document.getElementById('modelText').textContent = data.Model

                // Fill up the form
                document.getElementById("FAStatus").value = data.FAStatus;
                document.getElementById("ShipmentDate").value = this.SetFormDate(data.ShipmentDate);
                //document.getElementById("FAStatus").value = data.PlanQty;
                document.getElementById("WithSR").value = data.WithSR;
                document.getElementById("Remarks").value = data.OrderRemarks;

                this.LoadTraceAbility(data.FinalShopOrder);
            } catch (error) {
                console.error('Error fetching data:', error);
            }
        }
        async LoadTraceAbility(shoporder) {
            try {
              const res = await getMethod('@Url.Action("GetTraceabilityData", "Assembly")', {
                  shopOrder: shoporder
              });

              if (!res?.Success) return;
                const data = res.data;
                //console.log(data);
                this.renderTable(data);
            } catch (error) {
                console.error('Error fetching data:', error);
            }
        }


        async HandleSubmit(e) {
            e.preventDefault();
            const formData = {
                RecordID: this.recordID,
                FAStatus: document.getElementById('FAStatus').value,
                ShipmentDate: document.getElementById('ShipmentDate').value,
                Mode: "",
                WithSR: document.getElementById('WithSR').checked,
                Remarks: document.getElementById('Remarks').value
            };

            await this.EditAssemblyStatus(formData);
        }

        async EditAssemblyStatus(formdata) {
            const savebtn = document.querySelector('#EditFinalAsembly .save-btn');
            savebtn.innerHTML = '<span>Saving...</span>';
            savebtn.disabled = true;

            const originalText = savebtn.innerHTML;

            try {
                const res = await postMethod('@Url.Action("UpdateAssemblyStats", "Assembly")', formdata);

                if (res?.Success) {
                    alert('Assembly status updated successfully!');
                    // Optionally reload data to reflect changes
                    //await this.LoadDetailsinfo();
                } else {
                    alert('Error: ' + (res?.Message || 'Could not save data.'));
                }
            } catch (error) {
                console.error('Save error:', error);
                alert('An error occurred while saving.');
            } finally {
                // Restore button state
                const saveBtn = document.querySelector('#EditFinalAsembly .save-btn');
                saveBtn.innerHTML = originalText;
                saveBtn.disabled = false;
            }
        }

        formatDate(dateString) {
            if (!dateString) return '';

            const timestamp = parseInt(dateString.match(/\d+/)[0]);
            const date = new Date(timestamp);

            return date.toLocaleDateString('en-US');
        }

        SetFormDate(aspNetDate) {
            if (!aspNetDate) return '';

            const match = aspNetDate.match(/\d+/);
            if (!match) return '';

            const date = new Date(parseInt(match[0]));
            return date.toISOString().split('T')[0];
        }


        /* ================= RENDER MAIN TABLE ================= */
        renderTable(data) {
            if (!this.tbody) return;

            if (data.length === 0) {
                this.tbody.innerHTML = `
             <tr>
                 <td colspan="8" style="text-align:center; padding:32px; color:#86868b;">
                     No data available.
                 </td>
             </tr>`;
                return;
            }

           



            const sectionMap = {
                1: "Molding",
                2: "Press",
                3: "Rotor",
                4: "Winding",
                5: "Circuit",
                9: "Final Assembly"
            };

            //const sectionMap = {
            //    1: ['badge-molding', 'AG'],
            //    2: ['badge-press', 'AF'],
            //    3: ['badge-rotor', 'BF'],
            //    4: ['badge-winding', 'WF'],
            //    5: ['badge-circuit', 'CE']
            //};

            const sectionCode = {
                1: "AG",
                2: "AF",
                3: "BF",
                4: "FG",
                5: "CE",
                9: "HD"
            };


            this.tbody.innerHTML = data.map(row => {
                let sectionLabel = '';

                switch (row.DepartmentID) {
                    case 2:
                        sectionLabel = '<span class="sectionbadge badge-press">AF</span>'
                        break;
                    case 1:
                        sectionLabel = '<span class="sectionbadge badge-molding">AG</span>'
                        break;
                    case 3:
                        sectionLabel = '<span class="sectionbadge badge-rotor">BF</span>'
                        break;
                    case 4:
                        sectionLabel = '<span class="sectionbadge badge-winding">FG</span>'
                        break;
                    case 5:
                        sectionLabel = '<span class="sectionbadge badge-circuit">CE</span>'
                        break;
                    default:
                        sectionLabel = '<span class="sectionbadge badge-final">HD</span>'
                        break;
                }

                
                return `
                    <tr>
                        <td>
                            <div class="flex items-center gap-2">
                                ${sectionLabel}
                                <span class="font-semibold">${this.escape(sectionMap[row.DepartmentID])}</span>
                            </div>
                        </td>
                        <td style="color:#515154; text-align:center;">${this.escape(row.TimeInput)}</td>
                        <td style="color:#515154; text-align:center;">${this.escape(row.ShopOrder)}</td>
                        <td style="color:#515154;">${this.escape(row.ProcessName)}</td>
                        <td style="color:#515154; text-align:center;">${this.escape(row.ItemNo)}</td>
                        <td style="color:#515154; text-align:center;">${this.escape(row.PreparedQuantity)}</td>
                        <td style="color:#515154; text-align:center;">${this.escape(row.Customer)}</td>
                        <td style="color:#515154; text-align:center;">${this.escape(row.Modeltype)}</td>
                        <td style="color:#515154; text-align:center;">${this.escape(row.SubAssyIssued)}</td>
                    </tr>`;
                        }).join('');
        }

        escape(str) {
            const d = document.createElement('div');
            d.textContent = str ?? '';
            return d.innerHTML;
        }
    }


    document.addEventListener('DOMContentLoaded', function () {
        const controller = new ShopOrderDetailsController();
        controller.init();
    });
</script>



