<input type="hidden" id="intID" value="@intID" />

<div class="content-row">
    <!-- Main content panel -->
    <div class="main-panel">
        <!-- Breadcrumb -->
        @*<div class="breadcrumb-card">
            <a href="#" class="breadcrumb-link" id="navcont">
                <iconify-icon icon="lucide:house" width="16"></iconify-icon>
                Manage Data
            </a>

            <span class="breadcrumb-separator">/</span>

            <span class="breadcrumb-current" id="modelText">
                Shop Order Details
            </span>
        </div>*@

        <!-- Shop Order Details Card -->
        <div class="details-card">
            <div class="Shopcard-header">
                <div class="Shopcard-dot"></div>
                <span class="Shopcard-header-text">Shop Order Details</span>
            </div>
            <div class="Shopcard-body">
                <div class="details-row">
                    <div class="detail-item">
                        <span class="detail-label" >Final Shop Order</span>
