
@{
    Layout = "~/Areas/Final/Views/Shared/_FinalAssemblyLayout.cshtml";
    var strLine = Request.QueryString["line"];
}

<input type="hidden" id="strLine" value="@strLine" />

<!-- TAB BAR -->
<div class="tab-bar" id="tabBar">
    <div class="tab active" id="tab-manage" data-tab="manage">
        <iconify-icon icon="lucide:database" width="15"></iconify-icon>
        <span class="tab-label" id="Linename">@strLine Data</span>
    </div>
</div>

<!-- TAB CONTENT PANELS -->
<div class="tab-content-area">

    <!-- Main panel -->
    <div class="tab-panel active" id="panel-manage">

        <div class="breadcrumb-card" style="display:none">
            <a href="#" id="navdata" class="breadcrumb-link">
                <iconify-icon icon="lucide:house" width="16"></iconify-icon>
                Manage Data
            </a>
        </div>

        <div class="page-header">
            <div class="action-buttons">
                <div class="search-input">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <circle cx="11" cy="11" r="8" />
                        <path d="m21 21-4.34-4.34" />
                    </svg>
                    <input type="text" placeholder="Search here ..." id="searchinput" />
                </div>
                <select id="filterdata" class="filter-chip text-sm font-medium" style="height:32px;">
                    <option value="-1">Filter By : ALL </option>
                    <option value="0">Filter By : Completed Material</option>
                    <option value="1">Filter By : Next Process</option>
                    <option value="2">Filter By : On Process</option>
                    <option value="3">Filter By : Done Schedule</option>
                </select>

              
            </div>

            <div>
                <div>
                    <!-- Legends -->
                    <div class="flex items-center gap-4 flex-wrap">
                        <div class="legends-group">
                            <span class="rounded-full bg-status-gray flex-shrink-0"></span>
                            <span class="text-label">Pending Model </span>
                        </div>

                        <div class="legends-group">
                            <span class="rounded-full bg-status-green flex-shrink-0"></span>
                            <span class="text-label">Completed Materials</span>
                        </div>



                        <div class="legends-group">
                            <span class="rounded-full bg-status-yellow flex-shrink-0"></span>
                            <span class="text-label">Next process</span>
                        </div>
                        <div class="legends-group">
                            <span class="rounded-full bg-status-blue flex-shrink-0"></span>
                            <span class="text-label">On Process Model</span>
                        </div>

                    </div>
                </div>
            </div>

        </div>

        <div class="devices-table-wrapper">
            <div class="table-scroll TrackTable">
                <table class="devices-table">
                    <thead>
                        <tr>
                            <th>Status</th>
                            <th>Final Shop Order/ Partno / Model</th>
                            <th>PCB</th>
                            <th>IMP</th>
                            <th>LW</th>
                            <th>MF</th>
                            <th>FP</th>
                            <th>STR</th>
                            <th>MP</th>
                            <th>WC</th>
                            <th>QTY</th>
                            <th>Plan Start</th>
                            <th>Dispatch</th>
                            <th>Note</th>
                            <th>IFS Finish Date</th>
                            <th>FA Status</th>
                            <th>Shipment</th>
                            <th>Mode</th>
                            <th>WITH SR</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
    <!-- Dynamic detail panels injected here by JS -->
</div>




<div class=" flex justify-between items-center p-3 border-t" style="width: 100%; position: fixed; z-index: 999; bottom: 0; left: 0; border-top: 1px solid #e5e5e5; background: white;">
    <div id="resultsText" class="text-sm" style="color:#86868b;">Showing <span id="newrecords"></span> of <span id="currentrecords">1,248</span> Records</div>
    <div class="flex gap-1">
        <span style="color: #8a8f9e; font-size: .9rem;"><iconify-icon icon="lets-icons:move-light" width="20"></iconify-icon> Change line </span>

        <span style="color: #8a8f9e; font-size: .9rem;"><iconify-icon icon="material-symbols-light:ads-click-rounded" style="font-size: 18px;"></iconify-icon> Double Click on the rows to see the Details..</span>
    </div>
</div>





@Html.Partial("_ShopOrdersModal")








<script type="module" asp-append-version="true">
    import {
        getMethod,
        postMethod
    } from '@Url.Content("~/Scripts/modules/index.js")';

  class ShopOrderListController {
    constructor() {
        this.selectedID = 0;
        this.operation = 0;
        this.selectedLine = "";
        this.currentRecord = 0;
        this.pageSize = 0;
        this.isFirstLoad = true;
        this.isFilter = false;

        this.tbody = document.querySelector('.devices-table tbody');
        this.searchinput = document.getElementById('searchinput');
        this.filterStatus = document.getElementById('filterdata');
        this.refreshbutton = document.getElementById('refreshbtn');
        this.strLine = document.getElementById('strLine').value;
        this.tabBar = document.getElementById('tabBar');
        this.contentArea = document.querySelector('.tab-content-area');
        this.openTabs = new Map(); // id -> { tab, panel }


        // For Bootstrap Modal
        this.moveModal = new bootstrap.Modal(document.getElementById('moveOrderModal'));
        this.moveCellModal = new bootstrap.Modal(document.getElementById('moveCellModal'));
        this.cancelModal = new bootstrap.Modal(document.getElementById('cancelNextmodal'));
        this.moveModalBody = document.getElementById('moveOrderModalBody');
        this.moveConfirmBtn = document.getElementById('moveOrderConfirmBtn');
        this.moveCellConfirmBtn = document.getElementById('moveCellConfirmBtn');
        this.cancelConfirm = document.getElementById('CancelID');
        this.pendingMoveId = null;
    }

    async init() {
        this.bindEvents();
        this.enableHorizontalDragScroll();
        await this.LoadLineShopOrderList();
    }

      bindEvents() {
        // Status badge click
        this.tbody.addEventListener('click', async (e) => {
            const badge = e.target.closest('button.selectedbadge');
            if (!badge) return;
            e.stopPropagation();

            const isStatus = Object.freeze({
                Blank: 0,
                NextProcess: 1,
                InProcess: 2,
                Completed: 3,
                Temporary: 4
            });

            const row = badge.closest('tr');
            const id = parseInt(row.dataset.id); // ID
            const orderStatus = parseInt(row.dataset.orderStatus); // OrderStatus
            const lineman = row.dataset.orderLine; // Line
            const operation = row.dataset.operational;
            const isComplete = row.dataset.checkstats === 'true';


            if (Number.isNaN(id) || Number.isNaN(orderStatus)) {
                console.error('Row missing required data attributes', row.dataset);
                return;
            }

            // if isCOmplete is false(incomplete from the shops)
            if (!isComplete) {
                if (orderStatus === isStatus.Temporary) {
                    alert("Already in process.");
                } else {
                    // if not updates the OrderStatus to 4 (In Process) and updates the row
                    const success = await this.updateOrderStatus(id, 4, line);
                    if (!success) return;

                    row.dataset.orderStatus = '4';
                    badge.className = 'selectedbadge selectedProcessInProgress'; // or whatever your "in process" class is
                    row.classList.add('bg-row-highlight');

                    await this.LoadLineShopOrderList();
                }
                return;
            }

            if (operation > 1) {
                alert("Model needs to complete other processes before proceeding to next process.");
                return;
            }

            // if the orderStatus(Next Process is set) Shows the Cancel Dialog
            if (orderStatus === isStatus.NextProcess) {
                this.selectedID = id;
                this.selectedLine = lineman;
                this.cancelModal.show();
                return;
            }


            if (orderStatus === isStatus.InProcess || orderStatus === isStatus.Completed) return;

            try {
                const res = await getMethod('@Url.Action("CheckIfAreadyCheckNext", "Assembly")', { line });
                if (res.data > 0) {
                    alert("Already selected the next process.");
                    return;
                }

                const success = await this.updateOrderStatus(id, OrderStatus.NextProcess, line);
                if (!success) return;

                row.dataset.orderStatus = String(OrderStatus.NextProcess);
                badge.className = 'selectedbadge selectedProcess';
                row.classList.add('bg-row-highlight');

                await this.LoadLineShopOrderList();
            } catch (err) {
                console.error('Failed to update order status', err);
                alert("Something went wrong updating the status. Please try again.");
            }
        });


        this.tbody.addEventListener('click', async (e) => {
             const movebtn = e.target.closest('button.selectmove');
             if (!movebtn) return;
             e.stopPropagation();

            const row = movebtn.closest('tr');
            const id = parseInt(row.dataset.id);

            this.selectedID = id;
            //this.operation
            this.moveModal.show();
        });

        this.tbody.addEventListener('click', async (e) => {
            const movebtn = e.target.closest('button.changeCell');
            if (!movebtn) return;
            e.stopPropagation();

            const row = movebtn.closest('tr');
            const id = parseInt(row.dataset.id);
            const operation = row.dataset.operational;
            console.log("Operation : " + operation);

            this.selectedID = id;
            this.Operational = operation;
            this.moveCellModal.show();
        })



        this.tbody.addEventListener('dblclick', (e) => {
            if (e.target.closest('button.selectedbadge')) return;
            const row = e.target.closest('tr');
            if (!row) return;

            const id = row.dataset.id;
            const label = row.querySelector('td:nth-child(2) .text-primary')?.textContent?.trim() || `Order ${id}`;
            this.openDetailTab(id, label);
        });




        // Tab bar: switch on click (close handled per-tab)
        this.tabBar.addEventListener('click', (e) => {
            const tab = e.target.closest('.tab');
            if (!tab || e.target.closest('.tab-close')) return;
            const targetId = tab.dataset.tab;
            this.switchTab(targetId);
        });

        // Manage Data tab explicit click
        document.getElementById('tab-manage').addEventListener('click', () => {
            this.switchTab('manage');
        });

        this.moveConfirmBtn.addEventListener('click', async () => {
            const targetLine = document.getElementById('moveline')?.value;

            if (!targetLine) {
                alert('Please select a Target line');
                return;
            }

            const res = await postMethod('@Url.Action("UpdateLineshopOrder", "Assembly")', {
                 recordID: this.selectedID,
                 Lineman: document.getElementById('moveline').value,
                 process: 0
             });

            if (res?.Success) {
                alert("Change Completed");
                await this.LoadLineShopOrderList();
              }




            this.moveModal.hide();

        });

        this.moveCellConfirmBtn.addEventListener('click', async () => {
            const targetLine = document.getElementById('moveCellline')?.value;

            if (!targetLine) {
                alert('Please select a Target line');
                return;
            }

            const res = await postMethod('@Url.Action("UpdateLineshopOrder", "Assembly")', {
                recordID: this.selectedID,
                Lineman: document.getElementById('moveCellline').value,
                process: this.Operational
             });

            if (res?.Success) {
                alert("Change Completed");
                await this.LoadLineShopOrderList();
            }

            this.moveCellModal.hide();

        });



        this.cancelConfirm.addEventListener('click', async () => {
            let res = await this.updateOrderStatus(this.selectedID, 0, this.selectedLine);
            if (res?.Success) {
                this.cancelModal.hide();
                await this.LoadLineShopOrderList();
            }
        });

        this.refreshbutton.addEventListener('click', async (e) =>{
            e.preventDefault();
            this.tbody.innerHTML = "";

            document.getElementById('searchinput').value = "";
            document.getElementById('filterdata').value = "0";
            this.currentPage = 1;
            this.pageSize = 20;

             await this.LoadLineShopOrderList();
        });


        // Search + filter debounce
       let debounceTimer;
        const debounced = () => {
            this.isFilter = true;
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => this.LoadLineShopOrderList(), 300);
        };
        this.searchinput.addEventListener('input', debounced);
        this.filterStatus.addEventListener('change', debounced);
      }


      enableHorizontalDragScroll() {

          const container = document.querySelector(".TrackTable");

          if (!container) return;

          let isDown = false;
          let startX;
          let scrollLeft;

          container.addEventListener("mousedown", (e) => {

              // Ignore buttons, inputs, selects, links
              if (
                  e.target.closest("button") ||
                  e.target.closest("input") ||
                  e.target.closest("select") ||
                  e.target.closest("a")
              ) {
                  return;
              }

              isDown = true;
              startX = e.pageX;
              scrollLeft = container.scrollLeft;

              container.classList.add("dragging");
              container.style.cursor = "grabbing";
          });

          document.addEventListener("mouseup", () => {
              isDown = false;
              container.classList.remove("dragging");
              container.style.cursor = "grab";
          });

          container.addEventListener("mousemove", (e) => {

              if (!isDown) return;

              e.preventDefault();

              const walk = (e.pageX - startX) * 2;

              container.scrollLeft = scrollLeft - walk;
          });

          container.style.cursor = "grab";
      }


    switchTab(tabId) {
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));

        document.getElementById(`tab-${tabId}`)?.classList.add('active');
        document.getElementById(`panel-${tabId}`)?.classList.add('active');
    }

    openDetailTab(id, label) {
        // If already open, just switch to it
        if (this.openTabs.has(id)) {
            this.switchTab(`row-${id}`);
            return;
        }

        // Build tab
        const tab = document.createElement('div');
        tab.className = 'tab';
        tab.id = `tab-row-${id}`;
        tab.dataset.tab = `row-${id}`;
        tab.innerHTML = `
            <iconify-icon icon="lucide:file-text" width="14"></iconify-icon>
            <span class="tab-label" title="${label}">${label}</span>
            <button class="tab-close" title="Close" aria-label="Close tab">
                <iconify-icon icon="lucide:x" width="13"></iconify-icon>
            </button>`;

        tab.querySelector('.tab-close').addEventListener('click', (e) => {
            e.stopPropagation();
            this.closeDetailTab(id);
        });

        this.tabBar.appendChild(tab);

        // Build panel with iframe
        const panel = document.createElement('div');
        panel.className = 'tab-panel';
        panel.id = `panel-row-${id}`;
        panel.innerHTML = `
            <iframe
                class="detail-iframe"
                src="@Url.Action("ShopOrderDetails", "Assembly")?id=${id}"
                title="Shop Order Details">
            </iframe>`;

        this.contentArea.appendChild(panel);
        this.openTabs.set(id, { tab, panel });

        this.switchTab(`row-${id}`);
    }

    closeDetailTab(id) {
        const entry = this.openTabs.get(id);
        if (!entry) return;

        entry.tab.remove();
        entry.panel.remove();
        this.openTabs.delete(id);

        // Return to Manage Data + refresh table
        this.switchTab('manage');
        this.LoadLineShopOrderList();
    }

    // ... rest of your existing methods unchanged
      async LoadLineShopOrderList() {

          try {

                if (this.isFirstLoad) {
                  this.showTableSkeleton();
                  await new Promise(resolve => requestAnimationFrame(resolve));
                  this.isFirstLoad = false;
                }

                const res = await getMethod('@Url.Action("LineShopOrderData", "Assembly")', {
                    Linename: this.strLine,
                    searchtext: document.getElementById('searchinput').value,
                    orderstatus: document.getElementById('filterdata').value
                });

                if (!res?.Success) {
                    this.tbody.innerHTML = `
                     <tr>
                         <td colspan="18" style="text-align:center;color:red;">
                             Failed to load data.
                         </td>
                     </tr>`;
                    return;
              };

              this.currentRecord = this.isFilter ? this.currentRecord : res.data.Total;

              if (this.currentRecord != 0) {
                  console.log(res.data.payload);
                   document.getElementById("currentrecords").textContent = this.currentRecord;
                  this.renderTable(res.data.payload ?? []);
                    //this.renderPagination(total ?? res.data.payload.length);
                } else {
                    this.tbody.innerHTML = `
                         <tr>
                             <td colspan="18" style="text-align:center;color:red;">
                                 Failed to load data.
                             </td>
                         </tr>`;
                }

            } catch (error) {
                console.error('Error fetching data:', error);

                this.tbody.innerHTML = `
                <tr>
                    <td colspan="18" style="text-align:center;color:red;">
                        Failed to load data.
                    </td>
                </tr>`;
            }
    }


      renderTable(data) {
          if (!this.tbody) return;

          const filterValue = parseInt(this.filterStatus.value);

          const filteredData = data.filter(row => {

              const hasCircuit = row.Circuit != null && row.Circuit.trim() !== '';
              const hasRotor = row.Rotor != null && row.Rotor.trim() !== '';
              const hasWinding = row.Winding != null && row.Winding.trim() !== '';
              const hasHarness = row.Harness != null && row.Harness.trim() !== '';
              const hasMolding = row.Molding != null && row.Molding.trim() !== '';
              const hasPress = row.Press != null && row.Press.trim() !== '';
              const hasMaterial = row.Material != null && row.Material.trim() !== '';

              const allComplete =
                  hasCircuit &&
                  hasRotor &&
                  hasWinding &&
                  hasHarness &&
                  hasMaterial &&
                  (hasMolding || hasPress);

              const orderStatus = parseInt(row.OrderStatus || 0);

              switch (filterValue) {
                  case 0: // Completed Material
                      return allComplete;

                  case 1: // Next Process
                      return allComplete && orderStatus === 1;

                  case 2: // On Process
                      return orderStatus === 2;

                  case 3: // Done Schedule
                      return orderStatus === 3;

                  default: // ALL
                      return true;
              }
          });

          // ✅ Update newrecords with the actual rendered count
          document.getElementById("newrecords").textContent = filteredData.length;


          if (filteredData.length === 0) {
              this.tbody.innerHTML = `
                <tr>
                    <td colspan="19" style="text-align:center; padding:32px; color:#86868b;">
                        No data available.
                    </td>
                </tr>`;
              return;
          }

          this.tbody.innerHTML = filteredData.map(row => {

              let molding = row.Molding
                  ? '<span class="sectionbadge badge-molding">AF</span>'
                  : '-';

              let press = row.Press
                  ? '<span class="sectionbadge badge-press">AG</span>'
                  : '-';

              let rotor = row.Rotor
                  ? '<span class="sectionbadge badge-rotor">BF</span>'
                  : '-';

              let winding = row.Winding
                  ? '<span class="sectionbadge badge-winding">FA</span>'
                  : '-';

              let circuit = row.Circuit
                  ? '<span class="sectionbadge badge-circuit">CE</span>'
                  : '-';

              let harness = row.Harness
                  ? '<span class="sectionbadge badge-harness">FG</span>'
                  : '-';

              let Material = row.Material
                  ? '<span class="sectionbadge badge-Material">DD</span>'
                  : '-';

              const hasCircuit = row.Circuit != null && row.Circuit.trim() !== '';
              const hasRotor = row.Rotor != null && row.Rotor.trim() !== '';
              const hasWinding = row.Winding != null && row.Winding.trim() !== '';
              const hasHarness = row.Harness != null && row.Harness.trim() !== '';
              const hasMolding = row.Molding != null && row.Molding.trim() !== '';
              const hasPress = row.Press != null && row.Press.trim() !== '';
              const hasMaterial = row.Material != null && row.Material.trim() !== '';

              const allComplete =
                  hasCircuit &&
                  hasWinding &&
                  hasRotor &&
                  hasHarness &&
                  hasMaterial &&
                  (hasMolding || hasPress);

              const orderStatus = parseInt(row.OrderStatus);

              let highlighted =
                  orderStatus === 2
                      ? 'bg-row-highlight'
                      : '';

              let selecthighlight = '';
              let isOperational = '';

              if (allComplete) {
                  switch (orderStatus) {
                      case 3:
                          selecthighlight = 'selectedComplete';
                          break;

                      case 2:
                          selecthighlight = 'selectedProcess';
                          break;

                      case 1:
                          selecthighlight = 'selectedNext';
                          break;

                      default:
                          selecthighlight = 'selectAvailable';
                          break;
                  }
              } else {
                  if (orderStatus === 2 || orderStatus == 4) {
                      selecthighlight = 'selectedProcess';
                  }
              }

              isOperational = row.Operational === 2 || row.Operational === 3 ? `<span> ${row.Operational}</span>` : "";


              return `
        <tr class="${highlighted} fade-in"
            data-order-line="${row.Line}"
            data-order-status="${orderStatus}"
            data-operational="${row.Operational}"
            data-checkstats ="${allComplete}"
            data-id="${row.RecordID}">

            <td class="fixedrow">
                <div style="display:flex;align-items:center;gap:1.5em;">
                    <button
                        class="selectedbadge ${selecthighlight}"
                        ${orderStatus === 2 || orderStatus === 3 ? 'disabled' : ''}>
                    </button>

                    <button class="selectmove">
                        <iconify-icon icon="lets-icons:move-light" width="20"></iconify-icon>
                    </button>
                     <button class="changeCell">
                          <iconify-icon icon="fluent-emoji-high-contrast:cl-button" width="20"></iconify-icon>
                          ${isOperational}
                    </button>
                </div>
            </td>

            <td style='text-align: left;'>
                <span class="text-primary font-medium">${row.FinalShopOrder}</span>
                <p style="margin:.2em 0;color:#8a8f9e;">${row.ItemNo}</p>
                <span style="font-weight:600;">${row.Model}</span>
            </td>

            <td>${circuit}</td>
            <td>${rotor}</td>
            <td>${harness}</td>
            <td>${molding}</td>
            <td>${press}</td>
            <td>${winding}</td>
            <td>${Material}</td>

            <td>${row.WC}</td>
            <td>${row.PlanQty}</td>
            <td>${this.formatDate(row.PlanStartDate)}</td>
            <td>${row.DispatchDate}</td>
            <td>${row.Note || ''}</td>
            <td>${this.formatDate(row.FinalFinishedDate)}</td>
            <td>${row.FAStatus || ''}</td>
            <td>${this.formatDate(row.ShipmentDate)}</td>
            <td>${row.ShipmentMode || ''}</td>
            <td>${row.WithSR ? 'With SR' : ''}</td>
        </tr>`;
          }).join('');
      }

    showTableSkeleton() {
          this.tbody.innerHTML = Array(10).fill(`
        <tr>
            ${Array(19).fill(`
                <td>
                    <div class="skeleton-cell"></div>
                </td>
            `).join('')}
        </tr>
        `).join('');
    }


      showLoader() {
          document.getElementById('loadingOverlay')
              ?.classList.add('show');
      }

      hideLoader() {
          document.getElementById('loadingOverlay')
              ?.classList.remove('show');
      }

   formatDate(dateString) {
            if (!dateString) return '';

            const timestamp = parseInt(dateString.match(/\d+/)[0]);
            const date = new Date(timestamp);

            return date.toLocaleDateString('en-US');
        }
     async updateOrderStatus(id, orderstatus, lineman) {
             try {

                 const res = await postMethod('@Url.Action("UpdateStatusLine", "Assembly")', {
                     recordID : id,
                     orderstats: orderstatus,
                     line: lineman
                 });

                 return res;

             } catch (err) {
                 console.error(err);
                 return false;
             }
        }


}

document.addEventListener('DOMContentLoaded', function () {
    const controller = new ShopOrderListController();
    controller.init();
});
</script>
