
@{
    Layout = null;
    var strLine = Request.QueryString["line"];
}


<input type="hidden" id="strLine" value="@strLine" />





<script type="module" asp-append-version="true">
    import {
        getMethod,
        postMethod
    } from '@Url.Content("~/Scripts/modules/index.js")';

    class ShopOrderListController {
        constructor() {
            this.strLine = document.getElementById('strLine').value;
            this.currentPage = 1;
            this.pageSize = 10;
            this.totalPages = 0;
            this.totalRecords = 0;
            this.init();
        }

        async init() {
            await this.LoadLineShopOrderList();
        }

        async LoadLineShopOrderList() {
            try {
                const res = await getMethod('@Url.Action("LineShopOrderData", "Assembly")', {
                    Linename: this.strLine
                });

                if (!res?.Success) return;
                console.log(res.data);

            } catch (error) {
                console.error('Error fetching data:', error);
            }
        }

        renderTable(records) {
            const tableBody = document.getElementById('ShopOrderSummaryOut');
            tableBody.innerHTML = '';
            records.forEach(record => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td>${record.status}</td>
                    <td>${record.shopOrder}</td>
                    <td>${record.partNo}</td>
                    <td>${record.model}</td>
                    <td>${record.pcb}</td>
                    <td>${record.imp}</td>
                    <td>${record.lw}</td>
                    <td>${record.mf}</td>
                    <td>${record.fp}</td>
                    <td>${record.fa}</td>
                    <td>${record.wc}</td>
                    <td>${record.qty}</td>
                    <td>${record.planStart}</td>
                    <td>${record.dispatchDate}</td>
                    <td>${record.bushNatural}</td>
                    <td><button class="action-btn" data-id="${record.id}">Action</button></td>
                `;
                tableBody.appendChild(row);
            });
        }



    }

    document.addEventListener('DOMContentLoaded', function () {
        const controller = new ShopOrderListController();
        controller.init();
    });
</script>