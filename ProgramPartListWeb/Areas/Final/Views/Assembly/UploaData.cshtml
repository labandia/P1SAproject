
@{
    Layout = "~/Areas/Final/Views/Shared/_ManageLayout.cshtml";
}
@Html.AntiForgeryToken()

<section style="padding: 30px 20px;">
    <!-- MAIN PANEL -->
    <!-- header section -->
    <div class="flex justify-between items-center mb-6">
        <div class="flex items-center gap-lg-3">
            <div>
                <h2 class="text-xl font-semibold mb-1" style="font-size: 24px;">Final Assembly Upload Data</h2>
                <p class="text-sm" style="color:#86868b;">Data Upload For the Final Assembly </p>
            </div>

            <!-- filters bar -->
            <div class="flex items-center gap-3 mb-4 flex-wrap">



            </div>
        </div>
        <div class="flex gap-3">
            <select id="filterdata" class=" filter-chip text-sm font-medium" style="display: none;">
