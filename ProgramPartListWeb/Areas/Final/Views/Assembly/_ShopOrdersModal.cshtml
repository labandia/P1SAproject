<div class="modal fade" id="cancelNextmodal" tabindex="-1" aria-labelledby="moveOrderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">

            <div class="modal-card-wrapper">
                <div class="modal-card">
                    <div class="modal-row">
                        <div class="icon-box bg-question-subtle">
                            <span class="text-question">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"></circle>
                                    <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3m.08 4h.01"></path>
                                </svg>
                            </span>
                        </div>
                        <div class="modal-text">
                            <p class="modal-title">Are you sure you want to cancel?</p>
                            <p class="modal-description">This action requires confirmation before proceeding.</p>
                        </div>
                    </div>
                    <div class="button-group">
                        <button class="btn btn-outline" data-bs-dismiss="modal">No</button>
                        <button class="btn btn-primary-dark" id="CancelID">Yes</button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>








