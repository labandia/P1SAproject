<!-- Bootstrap Modal (dynamic, shown on load) -->
<div class="modal fade" id="uploadStatusModal" tabindex="-1" aria-labelledby="uploadModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="true">
    <div class="modal-dialog modal-dialog-centered upload-modal-dialog">
        <div class="modal-content custom-modal-card">
            <!-- entire content replicates original UploadStatusModal without Tailwind -->
            <div class="modal-body-custom">

                <!-- header: icon, title, close button -->
                <div class="modal-header-custom">
                    <div class="header-left">
                        <div class="icon-badge">
                            <span style="display: inline-flex; align-items: center; justify-content: center; width: 18px; height: 18px;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" color="var(--primary)">
                                    <path d="M12 13v8m-8-6.101A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242"></path>
                                    <path d="m8 17l4-4l4 4"></path>
                                </svg>
                            </span>
                        </div>
                        <div class="title-section">
                            <h2>Upload in Progress</h2>
                            <p><span id="modalFileName">filename</span> • <span id="modalFileMeta"></span></p>
                        </div>
                    </div>
                    <button type="button" class="close-btn-custom" data-bs-dismiss="modal" aria-label="Close">
                        <span style="display: inline-flex; align-items: center; justify-content: center; width: 16px; height: 16px;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M18 6L6 18M6 6l12 12"></path>
                            </svg>
                        </span>
                    </button>
                </div>

                <!-- progress bar + stats -->
                <div class="progress-card">
                    <div class="progress-label-row">
                        <span class="progress-label">Uploading files...</span>
                        <span class="progress-percent" id="modalProgressPct">0%</span>
                    </div>
                    <div class="progress-bar-bg">
                        <div class="progress-fill"></div>
                    </div>
                    <div class="stats-row">
                        <div class="stat-item"><span class="stat-dot green"></span><span class="stat-text"><strong>2</strong> Completed</span></div>
                        <div class="stat-item"><span class="stat-dot primary"></span><span class="stat-text"><strong>2</strong> Uploading</span></div>
                        <div class="stat-item"><span class="stat-dot gray"></span><span class="stat-text"><strong>1</strong> Queued</span></div>
                        <div class="stat-item"><span class="stat-dot red"></span><span class="stat-text"><strong>1</strong> Failed</span></div>
                    </div>
                </div>

                <!-- file table (identical data, no tailwind) -->
                <div style="max-height: 300px; overflow-y: auto;" id="modalTableScroll">
                    <table class="file-table">
                        <thead>
                            <tr>
                                <th>Shop Order</th>
                                <th>Part No</th>
                                <th>Model</th>
                                <th>WC</th>
                                <th>Plan Start</th>
                                <th>Result</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>

                <!-- footer actions (Cancel, Retry, Background) -->
                <div class="modal-footer-custom">
                    <div>
                        <span>Completed</span>
                        <p>Row 0 of 0 ✔ 0 ✘ 0</p>
                    </div>
                    <div class="action-group">
                        <button type="button" class="btn-outline-muted" id="cancelUploadBtn">Cancel Upload</button>

                        <button type="button" class="btn-primary-custom" id="continueBgBtn">Continue in Background</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>






