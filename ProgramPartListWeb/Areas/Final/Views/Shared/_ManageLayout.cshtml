
<!DOCTYPE html>

<html lang="en">
<head>
    @Html.Partial("_SystemConfig")

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>FINAL ASSEMBLY SCHEDULE PERFORMANCE AND TRACKING DASHBOARD </title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">


    <script src="~/Scripts/Shared/bootstrap.bundle.min.js"></script>
    <script src="~/Scripts/iconify-icon.min.js"></script>
    <link href="~/Content/Shared/bootstrap.min.css" rel="stylesheet" />
    @*@Styles.Render("~/Content/planning-css")*@
    <link href="~/Content/css/FinalAssembly.css" rel="stylesheet" />
    @Scripts.Render("~/bundles/shared-js")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>

    <div class="app-wrapper">
        <!-- Header -->
        <header class="header">

            <div class="logo-area">
                <div class="logo-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z" /></svg>
                </div>
                <span class="logo-text">Final Assembly Schedule Performance and Tracking Data</span>
            </div>

          

            <div class="header-actions">
               
                <div class="divider"></div>
                <button class="icon-btn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10.268 21a2 2 0 0 0 3.464 0m-10.47-5.674A1 1 0 0 0 4 17h16a1 1 0 0 0 .74-1.673C19.41 13.956 18 12.499 18 8A6 6 0 0 0 6 8c0 4.499-1.411 5.956-2.738 7.326" /></svg>
                </button>
                <button class="icon-btn" id="ExitDash">
                    <iconify-icon icon="solar:exit-bold" width="20"></iconify-icon>
                </button>
                
            </div>


        </header>

        <div class="main-layout">
            <!-- Sidebar -->
            <aside class="sidebar">
                <a href="#" id="pagelink" class="sidebar-item active">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                        <rect x="3" y="3" width="8" height="8" rx="1" />
                        <rect x="13" y="3" width="8" height="8" rx="1" />
                        <rect x="3" y="13" width="8" height="8" rx="1" />
                        <rect x="13" y="13" width="8" height="8" rx="1" />
                    </svg>
                </a>

                <a href="/Final/Assembly/UploaData" class="sidebar-item ">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                        <path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242" />
                        <path d="M12 12v9m-3-3 3 3 3-3" />
                    </svg>
                </a>


              
                <div class="sidebar-bottom">
                    <button class="sidebar-item"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10" /><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3m.08 4h.01" /></svg></button>
                    <div class="sidebar-time">8:20am</div>
                </div>
            </aside>

            <!-- Main content -->
            <main class="content">        
                @RenderBody()

            </main>
        </div>
    </div>



 
    <script src="~/Scripts/Shared/Global.js"></script>
    <script type="text/javascript">
        const nav = document.getElementById('pagelink');
        const linkColor = document.querySelectorAll('.sidebar-item');

        function colorLink() {
            linkColor.forEach(l => l.classList.remove('active'))
            this.classList.add('active')
        }

        linkColor.forEach(l => l.addEventListener('click', colorLink))

        nav.addEventListener('click', function (e) {
            e.preventDefault();
            let getLine = localStorage.getItem("LineSet");
            window.location.href =
                '@Url.Action("ShopOrderLine", "Assembly")?Line=' +
                encodeURIComponent(getLine);
        });

        document.getElementById("ExitDash").addEventListener("click", (e) => {
            e.preventDefault();
             window.location.href =
                 '@Url.Action("Dashboard", "Assembly")';
        });
    </script>
</body>
</html>
