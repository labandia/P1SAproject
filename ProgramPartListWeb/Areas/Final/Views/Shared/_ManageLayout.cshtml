
<!DOCTYPE html>

<html lang="en">
<head>
    @Html.Partial("_SystemConfig")

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>FINAL ASSEMBLY SCHEDULE PERFORMANCE AND TRACKING DASHBOARD </title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">


    <script src="~/Scripts/Shared/bootstrap.bundle.min.js"></script>
    <script src="~/Scripts/iconify-icon.min.js"></script>
    <link href="~/Content/Shared/bootstrap.min.css" rel="stylesheet" />
    @*@Styles.Render("~/Content/planning-css")*@
    <link href="~/Content/css/FinalAssembly.css" rel="stylesheet" />
    <link href="~/Content/css/Animation.css" rel="stylesheet" />
    @Scripts.Render("~/bundles/shared-js")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>
    <!-- Page Transition Overlay -->
    <div class="page-transition-overlay" id="pageTransitionOverlay">
        <div class="boxes">
            <div class="box"><div></div><div></div><div></div><div></div></div>
            <div class="box"><div></div><div></div><div></div><div></div></div>
            <div class="box"><div></div><div></div><div></div><div></div></div>
            <div class="box"><div></div><div></div><div></div><div></div></div>
        </div>
        <span class="loader-text">Loading...</span>
    </div>



    <div class="app-wrapper">
        <!-- Header -->
        <header class="header">

            <div class="logo-area">
                <div class="logo-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z" /></svg>
                </div>
                <span class="logo-text">Final Assembly Schedule Performance and Tracking Data</span>
            </div>



            <div class="header-actions">
                <div class="badge badge-muted">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round"
                         style="color:var(--color-muted-foreground)">
                        <path d="M8 2v4m8-4v4" />
                        <rect width="18" height="18" x="3" y="4" rx="2" />
                        <path d="M3 10h18" />
                    </svg>
                    <span id="currentDate"
                          style="font-size:var(--text-sm);font-weight:500"></span>
                </div>
                <div class="badge badge-online">
                    <span class="dot-online"></span>
                    <span id="liveTime"></span>
                </div>



                <div class="divider"></div>

            </div>


        </header>

        <div class="main-layout">
            <!-- Sidebar -->
            <aside class="sidebar">
                <a href="/Final/Assembly/Dashboard" id="pagelink" class="sidebar-item ">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                        <rect x="3" y="3" width="8" height="8" rx="1" />
                        <rect x="13" y="3" width="8" height="8" rx="1" />
                        <rect x="3" y="13" width="8" height="8" rx="1" />
                        <rect x="13" y="13" width="8" height="8" rx="1" />
                    </svg>
                </a>

                <a href="/Final/Assembly/UploaData" class="sidebar-item ">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                        <path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242" />
                        <path d="M12 12v9m-3-3 3 3 3-3" />
                    </svg>
                </a>

                <a href="/Final/Assembly/LineData" class="sidebar-item ">
                    <iconify-icon icon="material-symbols-light:table-outline" width="20"></iconify-icon>
                </a>


                @*<a href="#" id="pagelink" class="sidebar-item active">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                <rect x="3" y="3" width="8" height="8" rx="1" />
                <rect x="13" y="3" width="8" height="8" rx="1" />
                <rect x="3" y="13" width="8" height="8" rx="1" />
                <rect x="13" y="13" width="8" height="8" rx="1" />
            </svg>
        </a>

        <a href="/Final/Assembly/UploaData" class="sidebar-item ">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                <path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242" />
                <path d="M12 12v9m-3-3 3 3 3-3" />
            </svg>
        </a>*@



                <div class="sidebar-bottom">
                    <button class="sidebar-item"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10" /><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3m.08 4h.01" /></svg></button>
                    <div class="sidebar-time">8:20am</div>
                </div>
            </aside>

            <!-- Main content -->
            <main class="content">
                @RenderBody()

            </main>
        </div>
    </div>




    <script src="~/Scripts/Shared/Global.js"></script>
    <script type="text/javascript">
        const pageTransition = {
            overlay: document.getElementById('pageTransitionOverlay'),
            show() {
                this.overlay.classList.add('active');
                requestAnimationFrame(() => this.overlay.classList.add('show'));
            },
            hide() {
                this.overlay.classList.remove('show');
                setTimeout(() => this.overlay.classList.remove('active'), 200);
            }
        };
        window.pageTransition = pageTransition;
        window.addEventListener('pageshow', () => pageTransition.hide());



        //const nav = document.getElementById('pagelink');
        const linkColor = document.querySelectorAll('.sidebar-item');
        const currentPath = window.location.pathname.toLowerCase();

        linkColor.forEach(link => {
            const href = link.getAttribute('href');
            if (href && currentPath.startsWith(href.toLowerCase())) {
                linkColor.forEach(l => l.classList.remove('active'));
                link.classList.add('active');
            }
        });

        @*nav.addEventListener('click', function (e) {
            e.preventDefault();
            let getLine = localStorage.getItem("LineSet");
            window.location.href =
                '@Url.Action("ShopOrderLine", "Assembly")?Line=' +
                encodeURIComponent(getLine);
        });

        document.getElementById("ExitDash").addEventListener("click", (e) => {
            e.preventDefault();
             window.location.href =
                 '@Url.Action("Dashboard", "Assembly")';
        });*@


        function updateClock() {

            const now = new Date();

            const dateText = now.toLocaleDateString('en-US', {
                month: 'short',
                day: '2-digit',
                year: 'numeric'
            });

            const timeText = now.toLocaleTimeString('en-US', {
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit'
            });

            const dateElement = document.getElementById('currentDate');
            const liveElement = document.getElementById('liveTime');

            if (dateElement)
                dateElement.textContent = dateText;

            if (liveElement)
                liveElement.textContent = `LIVE ${timeText}`;
        }


        updateClock();
        setInterval(() =>updateClock(), 1000);
    </script>
</body>
</html>
