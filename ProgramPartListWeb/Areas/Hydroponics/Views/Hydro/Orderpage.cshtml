    // ========================== LOAD REQUEST DATA ==============================
    const RequesDataList = async () => {
        const startDate = document.querySelector("#startDate").value || "";
        const chamberType = $("#categoryFilter").val() || 0;
        const status = $("#stockStatusFilter").val() || "all";
        const endDate = $("#endDate").val() || "";

        let obj = {
            chamberType: chamberType,
            prefix: "CR",
            status: status,
            startDate: startDate,
            endDate: endDate,
            page: currentPage,
            pageSize: pageSize
        };

        try {
            let res = await GetMethod('@Url.Action("GetAllRequestList", "Hydro")', obj);


            if (res && res.Success) {
                requestData = res.data.Data || res.Data || [];
                const total = res.data?.Total ?? requestData.length;

                if (requestData.length === 0) {
                    const TableData = $("#chamberOrdersTableBody");
                    TableData.empty();
                    $("#chamberOrdersTableBody").html(`<tr><td colspan="9" style="text-align:center; color:#888;">⚠️ No matching records</td></tr>`);
                }


                if (total > 0) {
                    //console.clear();
                    renderfirstselect(requestData[0])
                    renderTable(requestData);
                    renderPagination(total);
                }
            } else {
                $("#chamberOrdersTableBody").html(`<tr><td colspan="9" style="text-align:center; color:#888;">⚠️ No matching records</td></tr>`);
            }
        } catch (err) {
            console.error("Error fetching data:", err);
            $("#chamberOrdersTableBody").html(`
                    <tr><td colspan="9" style="text-align:center; color:red;">Failed to load data</td></tr>
                `);
        }
    };

    // ========================== FIRST SELECTION ================================
    function renderfirstselect(data) {
        console.log(data);
        const percent = Math.round(parseFloat(data.CompletionPercent) || 0);
        const assemblyPercent = Math.round(parseFloat(data.AssemblyStats) || 0);

        const partsUI = getStatusUI(percent);
        const assemblyUI = getStatusUI(assemblyPercent);


        // Parts
        $("#PartsStatusValue").text(partsUI.text);
        $("#PartsStatusIcon")
            .attr("icon", partsUI.icon)
            .css("color", partsUI.color);

        // Assembly
        $("#AssemblyStatusValue").text(assemblyUI.text);
        $("#AssemblyStatusIcon")
            .attr("icon", assemblyUI.icon)
            .css("color", assemblyUI.color);


        selectedOrderID = data.OrderID;
        $("#Tdate").html(data.TargetDate);
        $("#detailTitle").text(data.OrderID);
        $("#CustomerNameValue").text(data.CustomerName);
        $("#PICValue").text(data.PIC);
        $("#TargetDateValue").text(data.TargetDate);
        $("#remarksValue").text(data.Remarks);

        $("#PartsStatusValue").text(`${percent}% Complete`);
        $("#AssemblyStatusValue").text(`${data.AssemblyStats}% Complete`);

        // ===== STATUS BADGE =====
        var status = (data.RequestStatus || "").toLowerCase();
        var $badge = $(".badgeSelect");

        // remove old classes
        $badge.removeClass("success danger planned");
    
        if (status === "ongoing") {
            $badge.addClass("danger").text("ONGOING");
        }
        else if (status === "completed") {
            $badge.addClass("success").text("COMPLETED");
        }
        else if (status === "for shipped") {
            $badge.addClass("warning").text("FOR SHIPPED");
        }
        else if (status === "planned") {
            $badge.addClass("planned").text("FOR PLANNED");
        }
        else {
            $badge.text(data.RequestStatus);
        }

    }

    // ========================== RENDER TABLE + PAGINATION ======================
    function renderTable(data) {
        const $tableBody = $("#chamberOrdersTableBody");
        $tableBody.empty();

        // If no Data found
        if (!data.length) {
            TableData.append(`<tr><td colspan="8" style="text-align:center; color:#888;">⚠️ No matching records</td></tr>`);
            return;
        }

        $.each(data, function (index, row) {
            const percent = Math.round(parseFloat(row.CompletionPercent) || 0);
            let barColor = "#e74c3c"; // red
            if (percent >= 70) barColor = "#27ae60"; // green
            else if (percent >= 40) barColor = "#f39c12"; // yellow
            console.log(row.RequestStatus);
            let statsCss = "";
            let statsname = "";

            if (row.RequestStatus == 'COMPLETED') {
                statsCss = 'success';
                statsname = 'Completed';
            } else if (row.RequestStatus == 'For Shipped') {
                statsCss = 'shipped'
                statsname = 'For Shipped';
            } else if (row.RequestStatus == 'PLANNED') {
                statsCss = 'planned'
                statsname = 'For Planned';
            } else {
                statsCss = 'danger'
                statsname = 'Ongoing';
            }

            const daysRemaining = calculateDaysRemaining(row.TargetDate);

            let orderId = "CR-0327265145";
            let cleanId = orderId.replace("CR-", "");


            const $row = $(`
                <tr>
                    <td><strong>${cleanId}</strong></td>
                    <td>${row.ChamberName ?? "-"}</td>
                    <td>${row.TargetDate ?? "-"}</td>
                    <td><span class="badge ${statsCss}">${statsname}</span></td>
                    <td style='text-align: center;'>${row.ChambersOrdered ?? "-"}</td>
                </tr>
            `);

            // store data
            $row.data("rowData", row);

            // click event
            $row.on("click", function () {
                // remove selected from all rows
                $("#chamberOrdersTableBody tr").removeClass("selected");

                // add to clicked row
                $(this).addClass("selected");

                // update details
                renderfirstselect($(this).data("rowData"));
            });

            $tableBody.append($row);

            // ✅ auto select first row
            if (index === 0) {
                $row.addClass("selected");
                renderfirstselect(row);
            }

      
        });
    }

    function getStatusUI(percent) {
        if (percent >= 70) {
            return {
                color: "#27ae60", // green
                icon: "lucide:check-circle-2",
                text: percent + "% Complete"
            };
        } else if (percent >= 40) {
            return {
                color: "#f39c12", // yellow
                icon: "lucide:alert-circle",
                text: percent + "% In Progress"
            };
        } else {
            return {
                color: "#e74c3c", // red
                icon: "lucide:x-circle",
                text: percent + "% Delayed"
            };
        }
    }

    // ========================== PAGINATION CONTROLS ============================
    function renderPagination(totalItems) {
        const totalPages = Math.ceil(totalItems / pageSize);
        const pagination = $("#MastertableContainer");
        pagination.empty();

        // Calculate "from" and "to" item numbers
        const startItem = (currentPage - 1) * pageSize + 1;
        const endItem = Math.min(currentPage * pageSize, totalItems);

        // Update text info
        $("#pagecountID").text(startItem > totalItems ? 0 : startItem);
        $("#totalpageID").text(endItem);
        $("#DatalengthID").text(totalItems);

        // Always render pagination, even if only 1 page
        let html = '';

        // Prev button
        html += `<button class="btn btn-outline" style="padding: 6px 12px; font-size: 12px;  data-page="${currentPage - 1}" ${currentPage === 1 ? "disabled" : ""}>Prev</button>`;

        // Page numbers
        for (let i = 1; i <= totalPages; i++) {
            html += `<button class="page-btn ${i === currentPage ? "active" : ""}" data-page="${i}">${i}</button>`;
        }

        // Next button
        html += `<button class="btn btn-outline" style="padding: 6px 12px; font-size: 12px; data-page="${currentPage + 1}" ${currentPage === totalPages ? "disabled" : ""}>Next</button>`;

        pagination.html(html);

        // If no items, show a disabled state
        if (totalItems === 0) {
            pagination.html(`<button class="page-btn" disabled>No data</button>`);
            $("#pagecountID").text(0);
            $("#totalpageID").text(0);
            $("#DatalengthID").text(0);
        }
    }

    // Pagination click handler
    $(document).on("click", ".page-btn", function () {
        const newPage = parseInt($(this).data("page"));
        if (!isNaN(newPage)) {
            currentPage = newPage;
            RequesDataList();
        }
    });

    // Calculate the Remaining Days
    function calculateDaysRemaining(targetDate) {
        const target = new Date(targetDate);
        const today = new Date();
        const diffTime = target - today;
        return Math.ceil(diffTime / (1000 * 60 * 60 * 24));
    }


    // ========================== FILTER EVENTS ================================
    $("#categoryFilter, #stockStatusFilter, #startDate, #endDate").on("change", function (e) {
        e.preventDefault();
        currentPage = 1;
        RequesDataList();
    });

    //$("#inventorySearch").on("keyup", function () {
    //    currentPage = 1;
