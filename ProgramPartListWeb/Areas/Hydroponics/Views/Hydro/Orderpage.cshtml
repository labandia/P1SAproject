
@{
    ViewBag.Title = "Orderpage";
    Layout = "~/Areas/Hydroponics/Views/Shared/HydroPartsLayout.cshtml";
}

<!-- Split Content Area -->
<div class="content-area">
    <!-- Left Panel: Table & Filters -->
    <div class="left-panel">
        <div class="filters-section">
            <div class="filters-group">
                <div class="filter-item">
                    <span class="futuristic-label">Chamber type</span>
                    <select id="categoryFilter" class="input-box">
                        <option value="0">All Types</option>
                        <option value="1">SHIBAKAWA</option>
                        <option value="2">NUPON</option>
                        <option value="3">SLIM TYPE</option>
                    </select>

                </div>
                <div class="filter-item">
                    <span class="futuristic-label">Status</span>
                    <select id="stockStatusFilter" class="input-box">
                        <option value="all">All Status</option>
                        <option value="ONGOING">Ongoing</option>
                        <option value="COMPLETED">Completed</option>
                        <option value="PLANNED">For Planned</option>
                        <option value="SHIPPED">For Shipping</option>
                    </select>
                </div>
                <div class="filter-item" style="display: none">
                    <span class="futuristic-label">Date Range</span>
                    <div class="date-inputs">
                        <input type="date" id="startDate" class="input-box" >
                        <input type="date" id="endDate" class="input-box" >
                    </div>
                </div>
            </div>


            <button id="Showadd" class="primarybtn" type="button">
                <iconify-icon icon="lucide:plus" style="font-size: 16px"></iconify-icon> New Orders
            </button>

        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Chamber Type</th>
                        <th>Order Date</th>
                        <th>Status</th>
                        <th style='text-align: center;'>Quantity</th>
                    </tr>
                </thead>
                <tbody id="chamberOrdersTableBody">


            </table>
        </div>
        <div class="table-footer">
            <span>Showing  <span id="pagecountID">-</span> to <span id="totalpageID">-</span> of  <span id="DatalengthID">-</span> Entries</span>
            <div id="MastertableContainer" style="display: flex; gap: 8px;">

            </div>
        </div>
    </div>


    <!-- Right Panel: Order Details (unchanged but fully visible) -->
    <aside class="right-panel">
        <div class="details-header">
            <div class="details-header-action">
                <div class="details-subtitle">
                    <iconify-icon icon="lucide:calendar" style="font-size: 14px"></iconify-icon>
                    Target Date on <span id="Tdate">24/11/2023</span>
                </div>
                <div>
                    <iconify-icon id="editOrder" icon="lucide:edit" style="font-size: 18px; margin-right: 10px; color: #2381ec;"></iconify-icon>
                    <iconify-icon id="deleteOrder" icon="lucide:trash-2" style="font-size: 18px; color: #ec4123;"></iconify-icon>
                </div>
            </div>
            <div style="height: 12px"></div>
            <h2 class="details-title" id="detailTitle"> -- N/A -- </h2>
            <div id="statusBadge" class="badgeSelect success" style="margin-top: 4px;">Completed</div>
        </div>
        <div class="details-content">
            <div class="detail-row">
                <span class="futuristic-label">Customer Name</span>
                <span class="detail-value" id="CustomerNameValue">-- N/A --</span>
            </div>
            <div class="detail-row">
                <span class="futuristic-label">Person In Charge (PIC)</span>
                <span class="detail-value" id="PICValue">-- N/A --</span>
            </div>
            <div class="detail-row">
                <span class="futuristic-label">Target Date</span>
                <span class="detail-value" id="TargetDateValue">-- N/A --</span>
            </div>
            <div class="divider"></div>
            <div class="status-grid">
                <div class="detail-row">
                    <span class="futuristic-label">Parts Status</span>
                    <span class="detail-value" style="display: flex; align-items: center; gap: 6px;">
                        <iconify-icon id="PartsStatusIcon" icon="lucide:circle" style="font-size:16px;"></iconify-icon>
                        <span id="PartsStatusValue">0</span>
                    </span>
                </div>
                <div class="detail-row">
                    <span class="futuristic-label">Assembly Status</span>
                    <span class="detail-value" style="display: flex; align-items: center; gap: 6px;">
                        <iconify-icon id="AssemblyStatusIcon" icon="lucide:circle" style="font-size:16px;"></iconify-icon>
                        <span id="AssemblyStatusValue">0</span>
                    </span>
                </div>
            </div>
            <div class="divider"></div>
            <div class="detail-row">
                <span class="futuristic-label">Remarks</span>
                <div class="remarks-box" id="remarksValue">
                    -- N/A --
                </div>
            </div>

            <div style="margin-top: auto; padding-top: 10px;">
                <button id="ViewParts" class="detailsbtn detailsbtn-outline" style="width: 100%;">
                    <iconify-icon icon="lucide:view" style="font-size: 16px"></iconify-icon>
                    View  Details
                </button>

              
            </div>

        </div>
    </aside>


</div>









