    //});

    // ========================== ROW CLICK EVENT ==============================
    $("#editOrder").on('click', function (e) {
        e.stopPropagation();
        var getStats = requestData.filter(res => res.OrderID === selectedOrderID);
        if (getStats) {
            $("#currentOrderStatus").val(getStats[0].RequestStatus);
            $("#EditCustomerName").val(getStats[0].CustomerName);
            $("#EditAssemblyStats").val(getStats[0].AssemblyStats);
            $("#EditRemarks").val(getStats[0].Remarks);
            $("#OrderID").val(getStats[0].OrderID);
            $("#Status").val(getStats[0].RequestStatus);
            $("#StatusUpdateModal").modal('show');
        }
    });
    $("#deleteOrder").on('click', function (e) {
        e.stopPropagation();

         Swal.fire({
             title: "Are you sure?",
             text: "You won't be able to revert this!",
             icon: "warning",
             showCancelButton: true,
             confirmButtonColor: "#3085d6",
             cancelButtonColor: "#d33",
             confirmButtonText: "Yes, delete it!"
         }).then(async (result) => {
             if (result.isConfirmed) {

                 let res = await postMethod('@Url.Action("DeleteManageOrders", "Hydro")', { OrderID: selectedOrderID });
                 if (res?.Success) {
                     Swal.fire({
                         title: "Deleted!",
                         text: `${selectedOrderID} is Delete successfully. All the Parts will be Back to the inventory`,
                         icon: "success",
                         timer: 1500,
                         showConfirmButton: false,
                         allowOutsideClick: false,   // prevent outside click
                         allowEscapeKey: false,      // optional: prevent ESC key close
                         allowEnterKey: false        // optional: prevent Enter key close
                     });
                     RequesDataList();
                 }
             }

         });
    })
    $("#ViewParts").on('click', function (e) {
        e.stopPropagation();
        window.location.href = `/Hydroponics/Hydro/OrderpageDetails?orderID=${selectedOrderID}`;
    });

    $(document).on('click', '.RequestRow', function (e) {
        e.stopPropagation();
        const rowId = $(this).attr('id').split('_')[1];
        window.location.href = `/Hydroponics/Hydro/OrderpageDetails?orderID=${rowId}`;
    });
    $(document).on('click', '.DeleteRow',  async function (e) {
        e.stopPropagation();

        Swal.fire({
            title: "Are you sure?",
            text: "You won't be able to revert this!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#3085d6",
            cancelButtonColor: "#d33",
            confirmButtonText: "Yes, delete it!"
        }).then(async (result) => {
            if (result.isConfirmed) {
                const rowId = $(this).attr('id').split('_')[1];

                let res = await postMethod('@Url.Action("DeleteManageOrders", "Hydro")', { OrderID: rowId });
                if (res?.Success) {
                    Swal.fire({
                        title: "Deleted!",
                        text: `${rowId} is Delete successfully. All the Parts will be Back to the inventory`,
                        icon: "success",
                        timer: 1500,
                        showConfirmButton: false,
                        allowOutsideClick: false,   // prevent outside click
                        allowEscapeKey: false,      // optional: prevent ESC key close
                        allowEnterKey: false        // optional: prevent Enter key close
                    });
                    RequesDataList();
                }
            }

        });


    });



    $(document).on('click', '.EditRow', function (e) {
        e.stopPropagation();
        const rowId = $(this).attr('id').split('_')[1];
        var getStats = requestData.filter(res => res.OrderID === rowId);
        if (getStats) {
            $("#currentOrderStatus").val(getStats[0].RequestStatus);
            $("#EditCustomerName").val(getStats[0].CustomerName);
            $("#EditAssemblyStats").val(getStats[0].AssemblyStats);
            $("#EditRemarks").val(getStats[0].Remarks);
            $("#OrderID").val(getStats[0].OrderID);
            $("#Status").val(getStats[0].RequestStatus);
            $("#StatusUpdateModal").modal('show');
        }
    });

    // ========================== ADD REQUEST ==============================
    const GetChamberDatalist = async () => {
        let res = await GetMethod('@Url.Action("GetChamberList", "Hydro")', {});
        if (res && res.Success) {
            const select = $("#ChamberID").empty().append(`<option value="0">-- select Chamber --</option>`);
            res.data.forEach(row => {
                select.append(`<option value="${row.ChamberID}">${row.ChamberName}</option>`);
            });
        }
    };

    $("#Showadd").on('click', function (e) {
        e.preventDefault();
        $("#AddRequestModal").modal("show");
    });

    addforms.addEventListener('submit', async function (e) {
        e.preventDefault();
        let formdata = new FormData(e.target);
        formdata.append('Prefix', "CR");

        let res = await postMethod('@Url.Action("NewAddRequestData", "Hydro")', formdata);
        if (res && res.Success) {
            RequesDataList();
            e.target.reset();
            $("#AddRequestModal").modal("hide");
        }
    });

    changeforms.addEventListener('submit', async function (e) {
        e.preventDefault();
        let formdata = new FormData(e.target);
        const data = Object.fromEntries(formdata);
        let res = await postMethod('@Url.Action("ChangeStatusRequest", "Hydro")', formdata);
        if (res && res.Success) {
            RequesDataList();
            e.target.reset();
            $("#StatusUpdateModal").modal("hide");
        }
    });

    // ========================== INITIAL LOAD ==============================
    $(document).ready(async () => {
        await Promise.all([RequesDataList(), GetChamberDatalist()]);
    });
</script>
