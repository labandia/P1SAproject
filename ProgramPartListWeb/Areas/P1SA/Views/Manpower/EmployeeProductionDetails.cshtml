<script type="module" asp-append-version="true">
    import {
        getMethod,
        postMethod
    } from '@Url.Content("~/Scripts/modules/index.js")';

    class EmployeeDetailsController {
        constructor() {
            this.init();
        }

        async init() {
            this.bindEvents();

            await this.fetchEmployeeData();
        }

        bindEvents() {
            document.getElementById("Backbtn")
                .addEventListener("click", () => {
                    window.location.href = `/P1SA/Manpower/Productions`;
                });



        }

        async fetchEmployeeData() {
            try {
                const ID = document.getElementById('employID').value;
                const res = await getMethod('@Url.Action("GetEmployeeDetails", "Manpower")', { employeeID: ID });
                console.log(res);
                if (!res?.Success) {
                    return;
                }

                this.populateEmployeeDetails(res.data);
            } catch (error) {
                console.error('Error fetching employee data:', error);
            }
        }

        populateEmployeeDetails(data) {
            // Populate the employee details in the UI using the fetched data
            // For example:
            document.querySelector('#EmployeeID').textContent = data.EmployeeCode;
            document.querySelector('#UserFullname').textContent = data.FullName;
            document.querySelector('#Department').textContent = data.DepartmentName;
            document.querySelector('#StatusName').textContent = data.StatusName;
        }
    }

    document.addEventListener("DOMContentLoaded", () => {
        const req = new EmployeeDetailsController();
        req.init();
    });
</script>
