
@{
    ViewBag.Title = "ManageEmployee";
    Layout = "~/Areas/P1SA/Views/Shared/_ManpowerLayout.cshtml";
}

@*<div class="decorator-bar"><span>// SYS.OP.LEADS</span><span>LAT: 45.92</span><span>LONG: -12.03</span><div class="tech-line flex-1"></div><span>[ STATUS: ONLINE ]</span></div>*@

<div class="page-header">
    <div class="page-title-container"><div class="title-accent-block"></div><h1 class="page-title">EMPLOYEE DATA LIST</h1></div>
    <button class="tech-button default" data-media-type="banani-button"><div style="width:16px;height:16px;display:flex;align-items:center;justify-content:center"><iconify-icon icon="lucide:download" style="font-size:16px;color:inherit"></iconify-icon></div> EXPORT_LOG</button>
</div>

<div class="filters-bar">

    <div class="filter-dropdowns">
        <select id="GenderID" class="tech-dropdown">
            <option value="2">GENDER : ALL</option>
            <option value="0">MALE</option>
            <option value="1">FEMALE</option>
        </select>

        <select id="AffiliID" class="tech-dropdown">
            <option value="0">POSITION : ALL</option>
            <option value="1">SUPERVISOR</option>
            <option value="2">JUNIOR SUPERVISOR</option>
            <option value="3">LEADER</option>
            <option value="4">TECHNICAL TRAINER</option>
            <option value="5">PRODUCTION OPERATOR</option>
            <option value="6">SDP</option>
        </select>

        <select id="AgencyID" class="tech-dropdown">
            <option value="0">COMPANY : ALL</option>
            <option value="1">SDP</option>
            <option value="2">TMS(Techinics MS)</option>
            <option value="3">SynergyOne</option>
            <option value="4">Onesource</option>
        </select>




    </div>
    <div class="spacer"></div>
    <div class="search-small">
        <div style="width:14px;height:14px;display:flex;align-items:center;justify-content:center">
            <iconify-icon icon="lucide:search" style="font-size:14px;color:inherit"></iconify-icon>
        </div>
        <span>SEARCH_NAME</span>

    </div>

    <select id="StatusID" class="tech-dropdown">
        <option value="0">SORT : Active</option>
        <option value="1">SORT : AWOL</option>
        <option value="2">SORT : Resigned</option>
    </select>


  
</div>

<div class="results-info"><div class="tech-line"></div><span class="results-text">SHOWING_INDEX: 01-10 OF 56</span><div class="tech-line flex-1"></div><div class="pagination-controls"><div class="pag-btn disabled" data-media-type="banani-button">&lt; PREV</div><div class="pag-btn" data-media-type="banani-button">NEXT &gt;</div></div></div>

<div class="tech-table-container">
    <div class="table-corner tl"></div><div class="table-corner tr"></div><div class="table-corner bl"></div><div class="table-corner br"></div>
    <table class="tech-table">
        <thead>
            <tr>
                <th>
                    <div class="th-content">ID // FULLNAME</div>
                </th>
                <th>
                    <div class="th-content">GENDER</div>
                </th>
                <th>
                    <div class="th-content">POSITION // AFFILIATION</div>
                </th>

                <th>
                    <div class="th-content">DATE_HIRED // LOS</div>
                </th>
                <th>
                    <div class="th-content">STAT_COND</div>
                </th>
                <th>
                    <div class="th-content">CATEGORY</div>
                </th>
            </tr>
        </thead>
        <tbody id="EmployeeBody">
          
        </tbody>
    </table>
</div>


<script type="module" asp-append-version="true">
    import {
        getMethod,
        postMethod
    } from '@Url.Content("~/Scripts/modules/index.js")';


    class EmployeeController {
        constructor() {
            this.EmployeeData = [];
            this.currentPage = 1;
            this.pageSize = 20;

            this.tbody = document.getElementById("EmployeeBody");
            //this.paginationContainer = document.getElementById("EmployeePagination");
        }

        async init() {
            this.bindEvents();

            await this.LoadEmployeeData();
        }

        bindEvents() {
            document.getElementById("GenderID")
                .addEventListener("change", () => {
                    this.currentPage = 1;
                    this.LoadEmployeeData();
                });

            document.getElementById("AffiliID")
                .addEventListener("change", () => {
                    this.currentPage = 1;
                    this.LoadEmployeeData();
                });

            document.getElementById("AgencyID")
                .addEventListener("change", () => {
                    this.currentPage = 1;
                    this.LoadEmployeeData();
                });

            document.getElementById("StatusID")
                .addEventListener("change", () => {
                    this.currentPage = 1;
                    this.LoadEmployeeData();
                });
        }

        /* ================= LOAD DATA ================= */
        async LoadEmployeeData() {
            const gender = document.getElementById("GenderID").value;
            const pos = document.getElementById("AffiliID").value;
            const agency = document.getElementById("AgencyID").value;
            const status = document.getElementById("StatusID").value;

            const objparams = {
                search: "",
                depid: 3,
                gender: gender,
                pos: pos,
                agency: agency,
                status: status,
                page: this.currentPage,
                pageSize: this.pageSize
            };

            try {

                const res = await getMethod('@Url.Action("GetEmployeelist", "Manpower")', objparams);

                if (!res?.Success) {
                    this.renderEmpty();
                    return;
                }

                this.EmployeeData = res.data ?? [];
                ////const total = res.data?.Total ?? this.requestData.length;

                this.renderTable(this.EmployeeData);
                //this.renderPagination(total);

            }
            catch (err) {
                console.error(err);
                this.renderError();
            }

        }


        renderTable(data) {
            console.log(data);

            this.tbody.innerHTML = "";

            if (!data.length) {
                this.renderEmpty();
                return;
            }

            const fragment = document.createDocumentFragment();

            data.forEach(row => {

                const tr = document.createElement("tr");
                tr.style.cursor = "pointer";

                tr.innerHTML = `  <tr>
                                <td>
                                  <div class="user-cell"><img src="https://storage.googleapis.com/banani-avatars/avatar%2Fmale%2F25-35%2FEuropean%2F2" class="cell-avatar" />
                                      <div class="user-details">
                                          <span class="user-name-bold">${row.FullName}</span>
                                          <span class="user-time">${row.EmployeeCode}</span>
                                      </div>
                                  </div>
                                </td>
                                    
                                <td>
                                 <div  class="source-text">${row.Gender ? 'FEMALE' : 'MALE'}</div>
                                </td>

                                <td> 
                                  <div class="contact-cell">
                                    <span>
                                      <div style="width:14px;height:14px;display:flex;align-items:center;justify-content:center;margin-right:8px">
                                      <iconify-icon icon="lucide:phone" style="font-size:14px;color:inherit"></iconify-icon>
                                       </div>${row.JobName}
                                    </span>

                                    <span>
                                      <div style="width:14px;height:14px;display:flex;align-items:center;justify-content:center;margin-right:8px">
                                      <iconify-icon icon="lucide:mail" style="font-size:14px;color:inherit"></iconify-icon>
                                      </div>${row.AgencyName}
                                   </span>
                                 </div>
                               </td>
   
                             <td>
                               <div class="contact-cell">
                                   <span>
                                     <div style="width:14px;height:14px;display:flex;align-items:center;justify-content:center;margin-right:8px">
                                     <iconify-icon icon="lucide:phone" style="font-size:14px;color:inherit"></iconify-icon>
                                      </div>${row.DateHired}
                                   </span>

                                   <span>
                                     <div style="width:14px;height:14px;display:flex;align-items:center;justify-content:center;margin-right:8px">
                                     <iconify-icon icon="lucide:mail" style="font-size:14px;color:inherit"></iconify-icon>
                                     </div>LOS : ${row.LOS} yrs
                                  </span>
                                </div>

                             </td>

                                <td>
                                  <span class="status-text success">${row.StatusName}</span>
                                </td>
    
                                <td>
                                  <span class="source-text">${row.CategoryName}</span>
                                </td>
                            </tr>
                     `;

                  tr.addEventListener("click", () => {
                    window.location.href = `/P1SA/Manpower/EmployeeDetails?EmployeeCode=${row.EmployeeCode}`;
                  });

                  fragment.appendChild(tr);
            });

            this.tbody.appendChild(fragment);

        }

        
        renderEmpty() {
            this.tbody.innerHTML = `<tr>
                 <td colspan="5" style="text-align:center;color:#999">
                     ⚠️ No records found
                 </td>
             </tr>`;
        }

        renderError() {
            this.tbody.innerHTML = `<tr>
             <td colspan="5" style="text-align:center;color:red">
                 Failed to load data
             </td>
         </tr>`;
        }

    }

    document.addEventListener("DOMContentLoaded", () => {
        const req = new EmployeeController();
        req.init();
    });
</script>