
@{
    Layout = null;
}

<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="@Url.Content("~/Content/Images/patrol .ico")">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewBag.Title</title>
    <link rel="preload" href="~/Content/fonts/Poppins-Regular.ttf" as="font" type="font/ttf" crossorigin="anonymous">

    <link href="~/Content/Shared/bootstrap.min.css" rel="stylesheet" />

    <link href="~/Content/css/RegistrationUI.css" rel="stylesheet" />

    @Styles.Render("~/Content/shared-css")

    @Scripts.Render("~/bundles/shared-js")
    @Scripts.Render("~/bundles/modernizr")
</head>


<body>
    <div class="MainWrapper">

        <div class="sidebar">
            <h2><i>📄</i> Registration No. </h2>
            <ul class="step-list">
                <li class="step-item active" data-step="1">
                    <span class="step-number">1</span>
                    Create new
                </li>
                <li class="step-item" data-step="2">
                    <span class="step-number">2</span>
                    Process Owner
                </li>

                <li class="step-item" data-step="3">
                    <span class="step-number">3</span>
                    Managers
                </li>

                <li class="step-item" data-step="4">
                    <span class="step-number">4</span>
                    Division Manager
                </li>
                <li class="step-item" data-step="5">
                    <span class="step-number">5</span>
                    Completed
                </li>
            </ul>
        </div>

        <div class="content">
            <div class="step-content active" style="padding-top: 1.5em;" id="step-1">
                <form method="post" enctype="multipart/form-data" autocomplete="off">
                    <div class="flex_align mb-4">
                        <a class="Backbtn" href="/PC/Patrol/PatrolReport"><i class="fa-solid fa-arrow-left"></i></a>
                        <h3 class="mb-0">Create New Registration No.</h3>
                    </div>



                    <div class="row mb-3">
                        <div class="col-12 col-sm-12 col-lg-4">
                            <label>Registration No. <small style="color: #a81818; font-weight: 600;">*</small> </label> <br />
                            @*<input type="text" placeholder="Type Registration No." name="RegNo" id="RegNo" required />*@
                            <div class="date-wrapper">
                                <span class="prefix" id="prefix">@ViewBag.Prefix-</span>
                                <input name="RegNo" id="RegNo" class="styled-date" type="text" placeholder="YYMMDD" readonly required>

                                <div class="calendar-icon-wrapper">
                                    <i class="fa-regular fa-calendar-days calendar-icon"></i>
                                    <input type="date" class="real-date-input" id="hiddenDatePicker" onchange="formatAndDisplayDate(this.value)">
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-12 col-lg-4">
                            <label>Dept. /Section Inspected <small style="color: #a81818; font-weight: 600;">*</small> </label>
                            <div class="select-container">
                                <select id="DepartmentID" name="DepartmentID" required>
                                    <option value="0">-- Select Department --</option>
                                    <option value="1">Molding</option>
                                    <option value="2">Press</option>
                                    <option value="3">Rotor</option>
                                    <option value="4">Winding</option>
                                    <option value="5">Circuit</option>
                                </select>
                            </div>

                        </div>

                        <div class="col-12 col-sm-12 col-lg-4 ">
                            <label>Person In Charge : </label> <br />
                            <div class="select-container">
                                <select id="Employee_ID" name="Employee_ID">
                                </select>
                            </div>
                        </div>
                    </div>


                    <div class="col-12 col-sm-12 col-lg-12 mb-3">
                        <label>1. Work Practice / Standard / Safety</label> <br />
                        <input type="hidden" value="1" id="Find1" name="Find1" />
                        <textarea placeholder="Type text here..." name="Inpects1" id="Inpects1" rows="3" cols="40" required></textarea>
                    </div>

                    <div class="col-12 col-sm-12 col-lg-12 mb-3">
                        <label>2. Identification and status of the product or materials.</label> <br />
                        <input type="hidden" value="2" id="Find2" name="Find2" required />
                        <textarea placeholder="Type text here..." name="Inpects2" id="Inpects2" rows="3" cols="40"></textarea>
                    </div>

                    <div class="col-12 col-sm-12 col-lg-12 mb-3">
                        <label>3. Condition and status of documents / records.</label> <br />
                        <input type="hidden" value="3" id="Find3" name="Find3" required />
                        <textarea placeholder="Type text here..." name="Inpects3" id="Inpects3" rows="3" cols="40"></textarea>
                    </div>

                    <div class="col-12 col-sm-12 col-lg-12 mb-3">
                        <label>4. Record of ‘start-up process check’ and monthly inspection</label> <br />
                        <input type="hidden" value="4" id="Find4" name="Find4" required />
                        <textarea placeholder="Type text here..." name="Inpects4" id="Inpects4" rows="3" cols="40"></textarea>
                    </div>

                    <div class="col-12 col-sm-12 col-lg-12 mb-3">
                        <label>5. Calibration of equipment and jigs used for measurement or inspection.</label> <br />
                        <input type="hidden" value="5" id="Find5" name="Find5" required />
                        <textarea placeholder="Type text here..." name="Inpects5" id="Inpects5" rows="3" cols="40"></textarea>
                    </div>

                    <div class="col-12 col-sm-12 col-lg-12 mb-3">
                        <label>6. Countermeasure and implementation of previous quality and safety</label> <br />
                        <input type="hidden" value="6" id="Find5" name="Find6" required />
                        <textarea placeholder="Type text here..." name="Inpects6" id="Inpects6" rows="3" cols="40"></textarea>
                    </div>





                    <div class="button-group">
                        @*<div>Your information is secure and encrypted</div>*@
                        <button class="btn-next floatingSend" type="submit" id="btnSave"><i class="fa-regular fa-paper-plane"></i></button>
                    </div>
                </form>



                <div class="col-4 col-sm-12 col-lg-4 mb-3">
                    <div class="form-group">
                        <label for="Employee_ID"><i class="fas fa-user-check"></i> Select Inspector</label>
                        <select id="selectedInspector" name="selectedInspector">
                            <option value="">-- Please select an inspector --</option>

                        </select>
                    </div>

                    <div class="signature-container" id="signature-display">
                        <div class="signature-placeholder" id="placeholder">
                            <i class="fas fa-signature" style="font-size: 48px; margin-bottom: 15px; color: #bdc3c7;"></i>
                            <p>Select an inspector to view their signature</p>
                        </div>
                        <img id="signature-image" class="signature-image" style="display: none;">

                        <div class="signature-Input" id="signature-Input" style="display: none;">
                            <i class="fas fa-signature" style="font-size: 48px; margin-bottom: 15px; color: #bdc3c7;"></i>
                            <p> No Signature Found. Please upload by click the Circle Icon. </p>
                        </div>

                    </div>


                </div>
            </div>
            <!-- Step 1: Create New Document -->
            <!-- Step 2: Person in Charge -->
            <div class="step-content" id="step-2">

            </div>

            <!-- Step 3: Document Details -->
            <div class="step-content" id="step-3">


                <!-- Step 4: Attachments -->
                <div class="step-content" id="step-4">

                </div>

                <!-- Step 5: Review & Submit -->
                <div class="step-content" id="step-5">

                </div>
            </div>


        </div>

    </div>



    <!-- Sequential Loader -->
    @Html.Partial("_LoaderUpload")

    <!-- Upload Files -->
    @Html.Partial("_UploadFiles")


    <script src="~/Scripts/bootstrap.min.js"></script>
    <script src="~/Scripts/Popper.min.js"></script>
    <script src="~/Scripts/signature_pad.umd.min.js"></script>
    <script type="text/javascript" >
        function formatAndDisplayDate(value) {
            if (!value) return;
            const date = new Date(value);
            const yy = String(date.getFullYear()).slice(-2);
            const mm = String(date.getMonth() + 1).padStart(2, '0');
            const dd = String(date.getDate()).padStart(2, '0');
            document.getElementById('RegNo').value = `${yy}${mm}${dd}`;
        }
    </script>


    <script type="module">
    "use strict";

      import {
          getMethod,
           postMethod,
          postMethodPublic
        } from '@Url.Content("~/Scripts/modules/index.js")';

        class RegisterControl {
            constructor() {
               /* ================= STATE ================= */
                this.prefix = "@ViewBag.Prefix";
                this.selectedInspector = null;
                this.currentStep = 1;
                this.totalSteps = 5;

                this.regisTable = [];
                this.emailTable = [];

                /* ================= DOM ================= */
                this.dom = {
                    form: document.getElementById("step-1"),
                    signatureImage: document.getElementById("signature-image"),
                    signatureInput: document.getElementById("signature-Input"),
                    placeholder: document.getElementById("placeholder"),
                    loader: document.getElementById("loader"),
                    doneBtn: document.getElementById("doneBtn"),
                    selectinspect: document.getElementById("selectedInspector")
                };

                /* ================= INIT ================= */
                this.init();
            }

            /* =========================================================
               INIT
            ========================================================= */
            init() {
                this.initTabs();
                this.initSignaturePad();
                this.initFileUpload();
                this.initFormSubmit();
                this.initSteps();
                this.initDoneButton();
                this.loadPageData();
                this.initformselectinspect();
            }

            /* =========================================================
               TABS
            ========================================================= */
            initTabs() {
                const tabs = document.querySelectorAll(".Mold_tab");
                const slider = document.querySelector(".Mold_slider");
                const contents = document.querySelectorAll(".Mold_content");

                tabs.forEach((tab, index) => {
                    tab.addEventListener("click", () => {
                        document.querySelector(".Mold_tab.active")?.classList.remove("active");
                        tab.classList.add("active");

                        slider.style.transform = `translateX(${index * 100}%)`;

                        contents.forEach(c => c.classList.remove("show"));
                        document.getElementById(tab.dataset.target).classList.add("show");
                    });
                });
            }

            /* =========================================================
              SIGNATURE PAD
           ========================================================= */
            initSignaturePad() {
                this.canvas = document.getElementById("signature-pad");
                this.signaturePad = new SignaturePad(this.canvas);

                document.getElementById("SignatureForms")
                    ?.addEventListener("submit", e => this.handleSignatureSubmit(e));
            }

            clearSignature() {
                this.signaturePad.clear();
            }


            async handleSignatureSubmit(e) {
                e.preventDefault();

                const blob = await (await fetch(this.signaturePad.toDataURL())).blob();
                const file = new File([blob], `Patrol_${Date.now()}.png`, { type: "image/png" });

                const formData = new FormData();
                formData.append("SignatureImage", file);
                formData.append("UserID", this.selectedInspector);

                await this.uploadSignature(formData);
            }

            async uploadSignature(formData) {
                const res = await fetch('@Url.Action("UploadSignature", "Patrol")', {
                    method: "POST",
                    body: formData
                });

                const data = await res.json();

                if (data?.success) {
                    this.dom.placeholder.style.display = 'none';
                    this.dom.signatureImage.style.display = 'block';
                    this.dom.signatureInput.style.display = 'none';
                    this.dom.signatureImage.src = `/User/GetSignatureImage?filename=${encodeURIComponent(data.Data)}`;

                    this.clearSignature();

                    const modal = bootstrap.Modal.getInstance(document.getElementById("uploadmodal"));
                    modal?.hide();
                }
            }

            /* =========================================================
                FILE UPLOAD
             ========================================================= */
            initFileUpload() {
                const fileInput = document.getElementById("fileInput");
                const uploadBtn = document.getElementById("uploadBtn");
                const saveBtn = document.getElementById("saveBtn");

                const previewContainer = document.getElementById("previewContainer");
                const previewImage = document.getElementById("previewImage");

                uploadBtn?.addEventListener("click", e => {
                    e.preventDefault();
                    fileInput.click();
                });

                fileInput?.addEventListener("change", e => {
                    const file = e.target.files[0];
                    if (!file) return;

                    if (file.size > 1024 * 1024) return alert("Max 1MB");

                    const valid = ["image/png", "image/jpeg", "image/jpg", "image/bmp", "image/gif"];
                    if (!valid.includes(file.type)) return alert("Invalid file");

                    const reader = new FileReader();
                    reader.onload = ev => {
                        previewImage.src = ev.target.result;
                        previewContainer.style.display = "block";
                    };
                    reader.readAsDataURL(file);
                });


                saveBtn?.addEventListener("click", async e => {
                    e.preventDefault();

                    if (!fileInput.files.length) {
                        alert("Upload signature first");
                        return;
                    }

                    const formData = new FormData();
                    formData.append("SignatureImage", fileInput.files[0]);
                    formData.append("UserID", this.selectedInspector);

                    await this.uploadSignature(formData);
                });
            }

            /* =========================================================
               FORM SUBMIT
            ========================================================= */
            initFormSubmit() {
                this.dom.form?.addEventListener("submit", e => this.handleSubmit(e));
            }


            async handleSubmit(e) {
                e.preventDefault();

                const formData = new FormData(e.target);
                formData.append("SelectedInspector", this.selectedInspector);
                formData.append("FindJson", this.getFindings(e.target));

                const data = Object.fromEntries(formData);
                const reg = `${this.prefix}-${data.RegNo}`;

                if (this.regisTable.some(r => r.RegNo === reg)) {
                    Swal.fire({ icon: "error", text: "Duplicate RegNo", timer: 1500, showConfirmButton: false });
                    return;
                }

                this.dom.loader.classList.add("active");
                this.resetSteps();

           
                if (res?.Success) this.startLoading(formData);
            }

            getFindings(form) {
                const data = Object.fromEntries(new FormData(form));

                return JSON.stringify(
                    Array.from({ length: 6 }, (_, i) => ({
                        RegNo: data.RegNo,
                        FindID: data[`Find${i + 1}`],
                        FindDescription: data[`Inpects${i + 1}`]
                    }))
                );
            }

            /* =========================================================
                 SELECTION OF INSPECTION
            ========================================================= */
            initformselectinspect() {
                this.dom.selectinspect.addEventListener("change", e => this.handleInspectChange(e));
            }

            handleInspectChange(e) {
                e.preventDefault();
                const selectedValue = e.target.value;
                if (selectedValue) {
                    let Getitems = this.emailTable.find(res => res.Employee_ID === selectedValue);
                    if (Getitems) {
                        if (Getitems.Signature) {
                            // Display the Signature Image
                            this.dom.placeholder.style.display = 'none';
                            this.dom.signatureInput.style.display = 'none';
                            this.dom.signatureImage.style.display = 'block';
                            this.dom.signatureImage.src = '/User/GetSignatureImage?filename=' + encodeURIComponent(Getitems.Signature);
                        } else {
                            // If No Signature Image
                            this.dom.placeholder.style.display = 'none';
                            this.dom.signatureImage.style.display = 'none';
                            this.dom.signatureInput.style.display = 'block';
                        }
                    }
                } else {
                    // Reset Back to Normal
                    this.dom.placeholder.style.display = 'block';
                    this.dom.signatureInput.style.display = 'none';
                    this.dom.signatureImage.style.display = 'none';
                }

                this.selectedInspector = selectedValue;
            }


            /* =========================================================
               STEPS
            ========================================================= */
            initSteps() {
                this.goToStep(1);
            }

            goToStep(step) {
                this.currentStep = step;

                document.querySelectorAll(".step-item").forEach((item, i) => {
                    item.classList.toggle("completed", i + 1 < step);
                    item.classList.toggle("active", i + 1 === step);
                });

                document.querySelectorAll(".step-content")
                    .forEach(c => c.classList.remove("active"));

                document.getElementById(`step-${step}`).classList.add("active");
            }

            resetSteps() {
                document.querySelectorAll(".step")
                    .forEach(s => s.classList.remove("active", "completed"));

                document.getElementById("progressFill").style.width = "0%";
                document.getElementById("progressText").textContent = "0%";
            }

            startLoading(formData) {
                const steps = [
                    {
                        id: "step1",
                        progress: 25,
                        action: () => postMethodPublic('@Url.Action("AddRegist", "Patrol")', formData)
                    },
                    {
                        id: "step2",
                        progress: 50,
                        action: () => postMethod('@Url.Action("GenerateRegistration", "Patrol")', formData)
                    },
                    {
                        id: "step3",
                        progress: 75,
                        action: () => postMethod('@Url.Action("SendEmailFromRegistration", "Patrol")', formData)
                    },
                    {
                        id: "step4",
                        progress: 100,
                        action: () => Promise.resolve({ Success: true }) // final step (no API)
                    }
                ];

                for (let i = 0; i < steps.length; i++) {
                    const step = steps[i];
                    const el = document.getElementById(step.id);

                    try {
                        // Activate step
                        el.classList.add("active");

                        // Update progress UI
                        document.getElementById("progressFill").style.width = `${step.progress}%`;
                        document.getElementById("progressText").textContent = `${step.progress}%`;

                        // 🔥 EXECUTE API HERE
                        const res = await step.action();

                        if (!res?.Success) {
                            throw new Error(`Step ${i + 1} failed`);
                        }

                        // Mark completed
                        el.classList.remove("active");
                        el.classList.add("completed");

                    } catch (error) {
                        console.error(error);

                        el.classList.add("error");

                        Swal.fire({
                            icon: "error",
                            text: `Process failed at step ${i + 1}`,
                        });

                        return; // STOP PROCESS
                    }
                }

                // All steps completed
                this.dom.doneBtn.classList.add("show");
            }

              /* =========================================================
                   DONE BUTTON
                ========================================================= */
                initDoneButton() {
                    this.dom.doneBtn?.addEventListener("click", () => {
                        this.dom.loader.classList.remove("active");
                        window.location.href = "/PC/Patrol/PatrolReport";
                    });
                }

                /* =========================================================
                   LOAD DATA
                ========================================================= */
                async loadPageData() {
                    try {
                        await Promise.all([
                            this.getRegistration(),
                            this.getEmails()
                        ]);
                    } catch (err) {
                        console.error(err);
                    }
                }

                async getRegistration() {
                    const res = await getMethod('@Url.Action("GetRegistrationNo", "Patrol")', {});
                    if (res?.Success) {
                        this.regisTable = res.data;
                    }
                }

                async getEmails() {
                    const res = await getMethod('@Url.Action("GetEmaiRegistration", "Patrol")', {});

                    if (res?.Success) {
                        let selectV2 = document.getElementById("selectedInspector");

                        let select = document.getElementById("Employee_ID");

                        this.emailTable = res.data;

                        this.emailTable.forEach(rowData => {
                            const option = document.createElement("option");
                            option.value = rowData.Employee_ID;
                            option.textContent = rowData.FullName;

                            if (rowData.Department_ID === 6) {
                                selectV2.appendChild(option);
                            } else {
                                select.appendChild(option);
                            }
                        });


                    }
            }


        }



        /* =========================================================
           START APP
        ========================================================= */
        document.addEventListener("DOMContentLoaded", () => {
            new RegisterControl();
        });
    </script>
</body>

