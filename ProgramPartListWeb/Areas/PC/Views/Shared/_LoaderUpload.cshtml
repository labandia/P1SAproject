
<div id="loader" class="loader-overlay">
    <div class="loader-box">
        <div class="loader-title">Generating Registration No...</div>

        <div class="progress-container">
            <div class="progress-bar" style="background: #f5f5f5;">
                <div class="progress-fill" id="progressFill"></div>
            </div>
            <div class="progress-text" id="progressText">0%</div>
        </div>

        <div class="step-list">
            <div class="step" id="step1">
                <div class="step-icon">
                    <i class="fas fa-database"></i>
                </div>
                <div class="step-contentloader">
                    <div class="step-title">Saving records to the Database</div>
                    <div class="step-description">Storing your Registration data securely</div>
                </div>
            </div>

            <div class="step" id="step2">
                <div class="step-icon">
                    <i class="fas fa-envelope"></i>
                </div>
                <div class="step-contentloader">
                    <div class="step-title">Creating a PDF file</div>
                    <div class="step-description">It will take while to generate a PDF file please Wait ...</div>
                </div>
            </div>

            <div class="step" id="step3">
                <div class="step-icon">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div class="step-contentloader">
                    <div class="step-title">Sending Email Message to the Process Owner</div>
                    <div class="step-description">Generating Email messsage ...</div>
                </div>
            </div>

            <div class="step" id="step4">
                <div class="step-icon">
                    <i class="fas fa-flag-checkered"></i>
                </div>
                <div class="step-contentloader">
                    <div class="step-title">Done and Close</div>
                    <div class="step-description">Process completed successfully</div>
                </div>
            </div>
        </div>

        <button class="done-btn" id="doneBtn"><i class="fa-solid fa-check"></i> Done</button>
    </div>
</div>

