@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Areas/Production1/Views/Shared/_FinalDashboard.cshtml";
}
<!-- Header -->
<header class="dashboard-header">
    <div class="header-title">
        <h1>
            Best Final Assembly Line
            <small>Dashboard</small>
        </h1>
    </div>
    <div class="header-brand">
        <div class="company">
            SANYO DENKI <span>PHILIPPINES, INC.</span>
        </div>
        <div class="tagline">Turn the Time into Power</div>
    </div>
</header>

<div class="dashboard" id="dashboard">


    <!-- Main content -->
    <div class="dashboard-main">
        <!-- Left column -->
        <section class="col-left">
            <h2 class="section-title">NCR Type</h2>
            <div class="ncr-bars">
                @*<div class="ncr-group">

                    </div>*@
                <div class="ncr-bar" data-type="inprocess">
                    <div id="ncr-inprocess" class="bar bg-primary" style="width:80%;">
                        <span class="emoji">😒</span>
                        <span>In-Process Defect</span>
                    </div>
                </div>
                <div class="ncr-bar" data-type="rejected">
                    <div id="ncr-rejected" class="bar bg-orange" style="width:70%;">
                        <span class="emoji">😢</span>
                        <span>Rejected Lot</span>
                    </div>
                </div>
                <div class="ncr-bar" data-type="claim">
                    <div id="ncr-claim" class="bar bg-red" style="width:65%;">
                        <span class="emoji">😭</span>
                        <span>Customer Claim</span>
                    </div>
                </div>
            </div>
            <div class="ncr-scale">
                <span>0</span><span>10</span><span>20</span><span>30</span><span>40</span><span>50</span>
                <span>60</span><span>70</span><span>80</span><span>90</span><span>100</span>
            </div>

            <h2 class="section-title" style="margin-top:1.2rem;">NCR Distribution</h2>
            <div class="dist-row" data-group="Group 1">
                <span class="label">Group 1</span>
                <div class="track">
                    <div id="dist-group1" class="fill bg-secondary" style="width:40%;">24%</div>
                </div>
            </div>
            <div class="dist-row" data-group="Group 2">
                <span class="label">Group 2</span>
                <div class="track">
                    <div id="dist-group2" class="fill bg-secondary" style="width:20%;">12%</div>
                </div>
            </div>
            <div class="dist-row" data-group="Cell Line">
                <span class="label">Cell Line</span>
                <div class="track">
                    <div id="dist-cell" class="fill bg-secondary" style="width:35%;">22%</div>
                </div>
            </div>
            <div class="dist-row" data-group="Harness">
                <span class="label">Harness</span>
                <div class="track">
                    <div id="dist-harness" class="fill bg-yellow" style="width:38%;">24%</div>
                </div>
            </div>
            <div class="dist-row" data-group="Oil Proof">
                <span class="label">Oil Proof</span>
                <div class="track">
                    <div id="dist-oil" class="fill bg-secondary" style="width:30%;">19%</div>
                </div>
            </div>

            <div class="badge-harness">
                <span class="icon">🐝</span>
                <div class="info">
                    <div class="title">WIRE HARNESS</div>
                    <span class="group-badge">BEST GROUP</span>
                    <div class="effort">EFFORT</div>
                </div>
                <span class="team">TEAM</span>
            </div>
        </section>

        <!-- Center column -->
        <section class="col-center">
            <h2 id="dashboard-title"
                style="font-family:var(--font-headings);font-weight:900;color:var(--color-primary);text-align:center;font-size:clamp(1.2rem,2vw,1.8rem);line-height:1.2;">
                July 2026<br />
                FA Line<br />
                Monitoring
            </h2>

            <div class="calendar">
                <div class="header">
                    <div class="month" id="monthText">July</div>
                    <div class="year" id="yearText">2026</div>
                </div>
                <div class="grid">
                    <div class="weekdays">
                        <div>SUN</div><div>MON</div><div>TUE</div><div>WED</div><div>THU</div><div>FRI</div><div>SAT</div>
                    </div>
                    <div class="days">
                        <div class="muted">31</div><div>1</div><div>2</div><div></div><div></div><div></div><div></div>
                        <div class="red">3</div><div>4</div><div>5</div><div>6</div><div>7</div><div>8</div><div>9</div>
                        <div class="red">10</div><div>11</div><div>12</div><div>13</div><div>14</div><div>15</div><div>16</div>
                        <div class="red">17</div><div>18</div><div>19</div><div>20</div><div>21</div><div>22</div><div>23</div>
                        <div class="red">24</div><div>25</div><div>26</div><div>27</div><div>28</div><div>29</div><div>30</div>
                    </div>
                </div>
            </div>

            <div class="best-group">
                <div class="thinking">🤭</div>
                <div>
                    <div class="best">BEST</div>
                    <div class="line">FA LINE</div>
                </div>
            </div>

            <div class="best-block">

                <div class="line-detail">
                    <span class="emoji-big">🤩</span>
                    <div>
                        <div class="line-number" id="best-line-number">LINE 10</div>
                        <div class="slogan">Quality starts with me!</div>
                    </div>
                </div>

            </div>
        </section>

        <!-- Right column -->
        <section class="col-right" id="line-list">
            <!-- Line rows will be populated by JavaScript -->
        </section>
    </div>
</div>

<!-- Award Slide Overlay -->
<div class="award-slide-overlay" id="awardSlideOverlay">
    <div class="award-slide">
        <div class="award-slide-left">
            <div class="award-ribbon">🏆</div>
            <h2 class="award-heading">Award Goes To</h2>
            <div class="award-winner-name" id="awardWinnerName">—</div>
            <div class="award-subtitle" id="awardSubtitle"></div>
        </div>
        <div class="award-slide-right">
            <img id="awardCertImage" src="" alt="Certificate"
                 onerror="this.onerror=null; this.src='@Url.Content("~/Content/Images/no-image.png")';" />
        </div>
    </div>
</div>
<!-- Tooltip -->
<div id="tooltip" class="tooltip-popup">
    <h4 id="tooltip-title">Title</h4>
    <ul id="tooltip-list"></ul>
    <button class="close-btn" id="tooltip-close">Close</button>
</div>

<!-- Refresh indicator -->
<div class="refresh-indicator" id="refreshIndicator">
    <span class="spinner"></span>
    <span id="refreshText">Updating...</span>
</div>

<div class="floating-comment-btn">
    <div class="comment-btn" id="commentBtn">
        <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
            <path d="M0 0h24v24H0z" fill="none" />
            <path fill="currentColor" fill-rule="evenodd" d="M21.455 5.416a.75.75 0 0 1-.096.943l-9.193 9.192a.75.75 0 0 1-.34.195l-3.829 1a.75.75 0 0 1-.915-.915l1-3.828a.8.8 0 0 1 .161-.312L17.47 2.47a.75.75 0 0 1 1.06 0l2.829 2.828a1 1 0 0 1 .096.118m-1.687.412L18 4.061l-8.518 8.518l-.625 2.393l2.393-.625z" clip-rule="evenodd" />
            <path fill="currentColor" d="M19.641 17.16a44.4 44.4 0 0 0 .261-7.04a.4.4 0 0 1 .117-.3l.984-.984a.198.198 0 0 1 .338.127a46 46 0 0 1-.21 8.372c-.236 2.022-1.86 3.607-3.873 3.832a47.8 47.8 0 0 1-10.516 0c-2.012-.225-3.637-1.81-3.873-3.832a46 46 0 0 1 0-10.67c.236-2.022 1.86-3.607 3.873-3.832a48 48 0 0 1 7.989-.213a.2.2 0 0 1 .128.34l-.993.992a.4.4 0 0 1-.297.117a46 46 0 0 0-6.66.255a2.89 2.89 0 0 0-2.55 2.516a44.4 44.4 0 0 0 0 10.32a2.89 2.89 0 0 0 2.55 2.516c3.355.375 6.827.375 10.183 0a2.89 2.89 0 0 0 2.55-2.516" />
        </svg>

        <span>Edit Data</span>
    </div>
</div>



<script type="module" asp-append-version="true">
    import {
        getMethod,
        postMethod
    } from '@Url.Content("~/Scripts/modules/index.js")';

    class FinalDashboardController {
        constructor() {
            this.refreshInterval = null;
            const today = new Date();

            this.monthName = today.toLocaleString('en-US', { month: 'long' });
            this.year = today.getFullYear();

            this.dashboardTitle = document.getElementById('dashboard-title');

            this.MonthTitle = document.getElementById('monthText');
            this.YearTitle = document.getElementById('yearText');

            console.log(this.monthName); // July
            console.log(this.year);      // 2026
            // ---- DOM refs ----
            this.lineList = document.getElementById('line-list');
            this.tooltip = document.getElementById('tooltip');
            this.tooltipTitle = document.getElementById('tooltip-title');
            this.tooltipList = document.getElementById('tooltip-list');
            this.tooltipClose = document.getElementById('tooltip-close');
            this.refreshText = document.getElementById('refreshText');
            this.bestLineNumber = document.getElementById('best-line-number');

            // ---- Award slide DOM refs ----
            this.dashboardEl = document.getElementById('dashboard');
            this.awardSlideOverlay = document.getElementById('awardSlideOverlay');
            this.awardWinnerName = document.getElementById('awardWinnerName');
            this.awardCertImage = document.getElementById('awardCertImage');
            this.awardSubtitle = document.getElementById('awardSubtitle');
            this.awardSlideDuration = 8000; // how long the award slide stays on screen, ms


            this.OpensDataManage = document.getElementById('commentBtn');


            // ---- Data generation ----
            this.lineNames = [
                'Line 01', 'Line 02', 'Line 03', 'Line 04', 'Line 05',
                'Line 06', 'Line 07', 'Line 08', 'Line 09', 'Line 10',
                'Line 11', 'Line 12', 'Line 13', 'Line 14', 'Line 15',
                'Line 16', 'Line 17', 'Line 18',
                'Cell Line', 'OilProof'
            ];

            this.groupMap = {
                'Line 01': 'L1', 'Line 02': 'L2', 'Line 03': 'L3', 'Line 04': 'L4',
                'Line 05': 'L5', 'Line 06': 'L6', 'Line 07': 'L7', 'Line 08': 'L8',
                'Line 09': 'L9', 'Line 10': 'L10', 'Line 11': 'L11', 'Line 12': 'L12',
                'Line 13': 'L13', 'Line 14': 'L14', 'Line 15': 'L15', 'Line 16': 'L16',
                'Line 17': 'L17', 'Line 18': 'L18',
                'Cell Line': 'CL',
                'OilProof': 'OP'
            };

            this.reverseGroupMap = Object.fromEntries(
                Object.entries(this.groupMap).map(([fullName, code]) => [code, fullName])
            );

            this.lineData = [];

        }

        async init() {
            this.dashboardTitle.innerHTML = `
                ${this.monthName} ${this.year}<br>
                FA Line<br>
                Monitoring
            `;

            this.MonthTitle.innerHTML = this.monthName;
            this.YearTitle.innerHTML = this.year;

            await this.fetch4MData();
            await this.fetchGroupData();

            this.generateData();      // <-- missing
            this.renderLines();

            // Needs to run AFTER renderLines() so the .line-row elements exist to highlight
            await this.fetchBestLines();

            this.refreshInterval = setInterval(async () => {
                await this.fetch4MData();
                await this.fetchGroupData();
                await this.fetchBestLines();

                // Refresh time
                this.refreshText.textContent = 'Updated ' + new Date().toLocaleTimeString();
            }, 10000);

            // Award slide: push in every 5 minutes
            this.awardSlideInterval = setInterval(() => {
                this.showAwardSlide();
            }, 1 * 60 * 1000);


            this.OpensDataManage.addEventListener('click', (e) => {
                window.location.href = '/Production1/FinalAssembly/ManagementData';
            });
        }

        // ---- 4M Factors dashboard ----
        async fetch4MData() {
            try {
                const res = await getMethod('@Url.Action("GetListof4ManFactor", "FinalAssembly")', {});
                if (!res?.Success) {
                    console.log('No data found in 4M ');
                    return;
                }
                this.renderNcrBars(res.data);
            } catch (error) {
                console.error('Error fetching 4M data:', error);
            }
        }

        // Resets a bar/fill to 0 and re-animates it to its target width,
        // recreating a "start page" fill-in effect on every refresh.
        animateBarFill(el, pct) {
            if (!el) return;

            // Kill any transition, snap to 0 instantly
            el.style.transition = 'none';
            el.style.width = '0%';
            el.classList.add('bar-refreshing');

            // Force reflow so the browser registers the 0% width
            // before we start the new transition
            void el.offsetWidth;

            requestAnimationFrame(() => {
                el.style.transition = 'width 0.8s cubic-bezier(0.22, 1, 0.36, 1)';
                el.style.width = pct + '%';
            });

            // Clean up the shimmer class after it plays once
            clearTimeout(el._shimmerTimeout);
            el._shimmerTimeout = setTimeout(() => {
                el.classList.remove('bar-refreshing');
            }, 850);
        }

        renderNcrBars(data) {
            // Map DB NCR Type names -> bar keys used in the HTML (data-type / id suffix)
            const typeMap = {
                'In-Process': 'inprocess',
                'Rejected Lot': 'rejected',
                'Customer Complaint': 'claim'
            };

            // Ignore the "Total" summary row, keep only the per-type rows
            const rows = (data || []).filter(r => r['NCRType'] !== 'Total');

            rows.forEach(row => {
                const key = typeMap[row['NCRType']];
                if (!key) return; // unmapped/unknown NCR type, skip safely

                const bar = document.getElementById(`ncr-${key}`);
                //const countEl = document.getElementById(`ncr-${key}-count`);
                if (!bar) return;

                const qty = row['Qty'] ?? 0;
                const pct = row['Percentage'] ?? 0;

                //console.log("Quantity: " + qty);
                //console.log("Percentage: " + pct);

                this.animateBarFill(bar, pct);
                //countEl.textContent = qty;
            });
        }


        async fetchGroupData() {
            try {
                const res = await getMethod('@Url.Action("GetListofGroupProcess", "FinalAssembly")', {});
                if (!res?.Success) {
                    console.log('No data found in Group Data ');
                    return;
                }

                //console.log(res.data);
                this.renderDistribution(res.data);
            } catch (error) {
                console.error('Error fetching group data:', error);
            }
        }

        renderDistribution(data) {
            // Percentages are now precomputed server-side in the 'FinalPercent' row (SortOrder 2)
            const finalPercentRow = (data || []).find(r => r['NCRType'] === 'FinalPercent');
            if (!finalPercentRow) {
                console.log('No FinalPercent row found in group data');
                return;
            }

            // Map DB group columns -> the bar ids used in the HTML.
            // 'Cell Line' = Group3, 'Harness' = Matprep, 'Oil Proof' = Oiloof per the display naming.
            const groupMap = [
                { key: 'Group1', barId: 'dist-group1' },
                { key: 'Group2', barId: 'dist-group2' },
                { key: 'Group3', barId: 'dist-cell' },
                { key: 'Matprep', barId: 'dist-harness' },
                { key: 'Oiloof', barId: 'dist-oil' }
            ];

            groupMap.forEach(({ key, barId }) => {
                const el = document.getElementById(barId);
                if (!el) return;

                const pct = finalPercentRow[key] ?? 0;

                this.animateBarFill(el, pct);
                el.textContent = `${pct}%`;
            });
        }

        async fetchBestLines() {
         try {
             const res = await getMethod('@Url.Action("GetBestLineList", "FinalAssembly")', {});
             if (!res?.Success) {
                 console.log('No data found in Group Data ');
                 return;
             }

             console.log(res.data);
             this.applyBestLines(res.data);
         } catch (error) {
             console.error('Error fetching group data:', error);
         }
       }

        applyBestLines(data) {
            const typeMap = {
                'In-Process': '😒',
                'Rejected Lot': '😢',
                'Customer Complaint': '😭'
            };

            document.querySelectorAll('.line-row').forEach(row => {
                const emojiSpan = row.querySelector('.emoji');
                if (emojiSpan) emojiSpan.textContent = '';
                row.classList.remove('highlight');
            });

            const setEmoji = (lineName, emoji) => {
                if (!lineName) return;
                const row = document.querySelector(`.line-row[data-line="${lineName}"]`);
                if (row) {
                    const span = row.querySelector('.emoji');
                    if (span) span.textContent = emoji;
                    row.classList.add('highlight');
                }
            };

            const normalizeLine = (line) => {
                if (!line) return line;
                if (line.startsWith('CL')) return 'Cell Line';
                if (line.startsWith('OP')) return 'OilProof';
                return this.reverseGroupMap[line] || line;
            };

            // Exclude the 'Total' row — its BestLine is null and its Qty
            // would otherwise win the "worst type" comparison below
            const rows = (data || []).filter(r => r['NCRtype'] !== 'Total');

            rows.forEach(row => {
                const emoji = typeMap[row['NCRtype']];   // reverted: 'NCRtype', lowercase t
                if (!emoji) return;

                const lineName = normalizeLine(row['BestLine']);
                setEmoji(lineName, emoji);

                const entry = this.lineData.find(d => d.name === lineName);
                if (entry) {
                    entry.total = row['Qty'] ?? 0;
                    entry.percentage = row['Percentage'] ?? 0;
                }
            });

            const worstTypeRow = rows.reduce((max, r) => (r.Qty > (max?.Qty ?? -1) ? r : max), null);
            if (worstTypeRow?.BestLine) {
                this.bestLineNumber.textContent = normalizeLine(worstTypeRow.BestLine);
            }
        }


        generateData() {
            this.lineData = this.lineNames.map(name => ({
                name: name,
                group: this.groupMap[name] || 'Other',
                inprocess: 0,
                rejected: 0,
                claim: 0
            }));
        }


        // ---- Render line rows ----
        renderLines() {
            this.lineList.innerHTML = '';
            this.lineData.forEach(d => {
                const row = document.createElement('div');
                row.className = 'line-row';
                row.dataset.line = d.name;
                row.dataset.group = d.group;
                row.innerHTML = `
                            <span class="name">${d.name}</span>
                            <span class="emoji"></span>
                        `;
                this.lineList.appendChild(row);
            });
            // Re-attach click events after render
            this.attachLineClicks();
        }

         // ---- Click handlers ----
        attachLineClicks() {
            document.querySelectorAll('.line-row').forEach(row => {
                row.addEventListener('click', (e) => {

                    const name = row.dataset.line;
                    const data = this.lineData.find(x => x.name === name);

                    if (!data) return;

                    const items = [
                        { name: 'In-Process', value: data.inprocess },
                        { name: 'Rejected', value: data.rejected },
                        { name: 'Claim', value: data.claim },
                        { name: 'Group', value: data.group }
                    ];

                    const rect = row.getBoundingClientRect();
                    this.showTooltip(
                        'Details for ' + name,
                        items,
                        rect.left + 10,
                        rect.bottom + 10
                    );
                });
            });
        }

        // ---- Tooltip functions ----
        showTooltip(title, items, x, y) {
            tooltipTitle.textContent = title;
            tooltipList.innerHTML = '';
            items.forEach(item => {
                const li = document.createElement('li');
                li.innerHTML = `<span>${item.name}</span><span>${item.value}</span>`;
                tooltipList.appendChild(li);
            });
            tooltip.style.left = x + 'px';
            tooltip.style.top = y + 'px';
            tooltip.classList.add('visible');
        }

        // ---- Award slide functions ----
        async fetchAwardData() {
            try {
                const res = await getMethod('@Url.Action("GetAwardData", "FinalAssembly")', {});
                console.log(res);

                if(res?.Success){
                    return res.data;
                }

            } catch (error) {
                console.error('Error fetching award data:', error);
                return null;
            }
        }

        async showAwardSlide() {
    
            const data = await this.fetchAwardData();
            if (!data) return;
            if (!data.IsDisplayed) return; // flagged off — skip this cycle silently

           const imagePath = data.CertificateImage
        ? `@Url.Action("DisplaytheImage", "FinalAssembly")?filename=${encodeURIComponent(data.CertificateImage)}`
        : '@Url.Content("~/Content/Images/no-image.png")';

            this.awardWinnerName.textContent = data.WinnerName ?? '';
            this.awardCertImage.src = imagePath; // ✅ now actually used
            this.awardSubtitle.textContent = data.Subtitle ?? '';
            this.awardSubtitle.style.display = data.Subtitle ? '' : 'none';

            this.dashboardEl.classList.add('slide-out-to-award');
            this.awardSlideOverlay.classList.remove('leaving');
            this.awardSlideOverlay.classList.add('active');

            clearTimeout(this._awardHideTimeout);
            this._awardHideTimeout = setTimeout(() => this.hideAwardSlide(), this.awardSlideDuration);
        }

        hideAwardSlide() {
            // Award slide exits to the left...
            this.awardSlideOverlay.classList.add('leaving');
            this.awardSlideOverlay.classList.remove('active');

            // ...dashboard re-enters from the left back to center
            this.dashboardEl.classList.remove('slide-out-to-award');

            clearTimeout(this._awardCleanupTimeout);
            this._awardCleanupTimeout = setTimeout(() => {
                this.awardSlideOverlay.classList.remove('leaving');
            }, 900);
        }
    }


    document.addEventListener('DOMContentLoaded', function () {
        const controller = new FinalDashboardController();
        controller.init();
    });
</script>
