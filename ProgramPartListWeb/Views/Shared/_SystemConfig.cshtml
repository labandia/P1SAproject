@{
    // Detect current Area
    var area = ViewContext.RouteData.DataTokens["area"] as string ?? "";

    // Default login
    string loginAction = "Login";
    string loginController = "User";

    // Area-specific logic
    switch (area)
    {
        case "Hydroponics":
            loginAction = "Index";
            loginController = "Hydro";
            break;

        case "Circuit":
            loginAction = "LogMainpage";
            loginController = "ProgramPartList";
            break;

        case "PC":
            loginAction = "Index";
            loginController = "Patrol";
            break;
        case "P1SA":
            loginAction = "Index";
            loginController = "Manpower";
            break;
    }

    // Build URL
    string loginUrl = Url.Action(loginAction, loginController, new { area = area });

    // System name
    string systemName = area == "" ? "Main System" : $"{area} System";

    // Api root (optional)
    string apiRoot = Url.Content("~/api/");
}

<script>
    window.AppConfig = {
        area: "@area",
        systemName: "@systemName",
        loginUrl: "@loginUrl",
        apiRoot: "@apiRoot"
    };
</script>


