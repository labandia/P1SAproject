		<!-- Access Token: 30 minutes -->
		<add key="config:JwtIssuer" value="http://p1saportalweb.sdp.com/" />
		<add key="config:JwtAudience" value="SecureApplicationUser" />



		<add key="owin:AutomaticAppStartup" value="false" />
		<add key="config:SMTPEmail" value="p1sa-processcontrol@sanyodenki.com" />

		<add key="AppEnvironment" value="Development" />
	</appSettings>
